# =============================================================================
# Search for Windows-specific files and delete them after migrating to Linux.
# The search starts in the current directory and includes all subdirectories.
# =============================================================================
function find_files() {
    find .  -type f  -name '~*'        -"$1" \
        -or -type f -iname '*.bat'     -"$1" \
        -or -type f -iname '*.exe'     -"$1" \
        -or -type f -iname '*.lnk'     -"$1" \
        -or -type f -iname desktop.ini -"$1" \
        -or -type f -iname thumbs.db   -"$1"
}

printf '%s\n' "Searching for Windows-specific files in '$PWD' and lower..."
find_files 'print'

read -rsp 'Press the Enter key to delete these Windows-specific files [Enter]: '

printf '\n%s\n' "Deleting Windows-specific files in '$PWD' and lower..."
find_files 'delete'

printf '%s\n' 'Done.'
