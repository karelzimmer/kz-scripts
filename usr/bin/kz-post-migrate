#!/usr/bin/env bash
# shellcheck shell=bash
# #############################################################################
# SPDX-FileComment: Delete Windows-specific files after migrating to Linux
#
# SPDX-FileCopyrightText: Karel Zimmer <info@karelzimmer.nl>
# SPDX-License-Identifier: CC0-1.0
# #############################################################################


# #############################################################################
# Imports
# #############################################################################

export TEXTDOMAIN='kz'
export TEXTDOMAINDIR='/usr/share/locale'
source /usr/bin/gettext.sh


# #############################################################################
# Constants
# #############################################################################

# List NORMAL last here so that -x doesn't bork the display.
readonly GREEN='\033[1;32m'
readonly NORMAL='\033[0m'


# #############################################################################
# Globals
# #############################################################################


# #############################################################################
# Functions
# #############################################################################

# This function searches for/deletes Windows-specific files.
function find_files() {
    find .  -type f  -name '~*'        -"$1" \
        -or -type f -iname '*.bat'     -"$1" \
        -or -type f -iname '*.exe'     -"$1" \
        -or -type f -iname '*.lnk'     -"$1" \
        -or -type f -iname desktop.ini -"$1" \
        -or -type f -iname thumbs.db   -"$1"
}


# #############################################################################
# Main
# #############################################################################

declare prompt=''
declare text=''

text=$(eval_gettext "Searching Windows-specific files in '\$PWD' and \
subfolders...")
printf '%s\n' "$text"
find_files 'print'

prompt=$(gettext "Press the Enter key to delete the Windows-specific files, \
or Ctrl-C to stop [Enter/Ctrl-C]: ")
read -rsp "$prompt"

text=$(eval_gettext "Deleting Windows-specific files in '\$PWD' and \
subfolders...")
printf '\n%s\n' "$text"
find_files 'delete'

text=$(gettext 'Complete!')
printf "$GREEN%s\n$NORMAL" "$text"
