# =============================================================================
# Remove Windows-specific files after migrating to Linux.
# =============================================================================
find .  -type f -iname '*.bat'     -delete \
    -or -type f -iname '*.exe'     -delete \
    -or -type f -iname '*.lnk'     -delete \
    -or -type f  -name '~*'        -delete \
    -or -type f -iname desktop.ini -delete \
    -or -type f -iname thumbs.db   -delete
