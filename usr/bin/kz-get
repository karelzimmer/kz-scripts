#!/usr/bin/env bash
# shellcheck shell=bash
# #############################################################################
# SPDX-FileComment: Download and install package kz
#
# SPDX-FileCopyrightText: Karel Zimmer <info@karelzimmer.nl>
# SPDX-License-Identifier: CC0-1.0
# #############################################################################


# #############################################################################
# Imports
# #############################################################################

export TEXTDOMAIN='kz'
export TEXTDOMAINDIR='/usr/share/locale'
source /usr/bin/gettext.sh

# #############################################################################
# Constants
# #############################################################################

readonly PROGRAM_NAME='kz-get'
readonly PROGRAM_LOGS="systemd-cat --identifier=$PROGRAM_NAME"

# List NORMAL last here so that -x doesn't bork the display.
readonly BOLD='\033[1m'
readonly NORMAL='\033[0m'

# #############################################################################
# Globals
# #############################################################################

declare OPTION_DEV=false

# #############################################################################
# Functions
# #############################################################################


# This function performs initial actions.
function init() {
    if [[ $* = -* && '--dev' == *"$*"* ]]; then
        OPTION_DEV=true
    elif [[ -n $* ]]; then
        printf '%s\n' 'kz get [-d | --dev]'
        exit 0
    fi

    # Script-hardening.
    set -o errexit
    set -o errtrace
    set -o nounset
    set -o pipefail

    # Trap signals.
    trap 'rm --force getkz* /tmp/kz-*.deb' EXIT
    trap 'err_report' ERR SIGHUP SIGINT SIGTERM
}


# This function reports errors.
# shellcheck disable=SC2317,SC2329
function err_report() {
    printf '\n' >&2
    journalctl  --all       \
                --lines=20  \
                --no-pager  \
                --pager-end \
                --identifier="$PROGRAM_NAME"
    text="$(eval_gettext \
"Program \$PROGRAM_NAME encountered an error.")"
    printf "$BOLD%s$NORMAL\n" "$text" >&2
}


# This function performs the script actions.
function process() {
    become_check
    sudo --validate || exit 1

    if grep --quiet --regexp='debian' /etc/os-release; then
        process_kz_deb_package
    elif grep --quiet --regexp='rhel\|fedora' /etc/os-release; then
        process_kz_rpm_package
    else
        printf "$BOLD%s$NORMAL\n" 'fatal: unknown os release' >&2
        exit 1
    fi
}

# This function checks if the user is allowed to become root and returns 0 if
# so, otherwise exits 0 with descriptive message.
function become_check() {
    local text=''

    if groups "$USER" | grep --quiet --regexp='sudo' --regexp='wheel'; then
        return 0
    else
        text=$(gettext 'Already performed by the administrator.')
        printf "%s\n" "$text"
        exit 0
    fi
}


# This function downloads and installs Debian package kz.
function process_kz_deb_package() {
    local install='install'
    local kz_deb_local_file=''
    local kz_deb_site_file=''
    local packages_url='https://karelzimmer.nl/assets/packages'

    if $OPTION_DEV; then
        kz_deb_site_file=$packages_url/kz-dev_4.2.1-1_all.deb
        kz_deb_local_file=$(mktemp -t "kz-dev-XXXXXXXXXX.deb")
    else
        kz_deb_site_file=$packages_url/kz_4.2.1-1_all.deb
        kz_deb_local_file=$(mktemp -t "kz-XXXXXXXXXX.deb")
    fi

    if type kz &> /dev/null; then
        install='reinstall'
    fi

    printf '%s' 'Download...'
    printf '%s\n' "Downloading $kz_deb_site_file" |& $PROGRAM_LOGS
    wget    --output-document="$kz_deb_local_file"  \
            "$kz_deb_site_file"                     |& $PROGRAM_LOGS
    # Prevent the message ...'/tmp/...deb' couldn't be accessed by user '_apt'.
    chmod o+r "$kz_deb_local_file"

    printf '\n%s' 'Update.....'
    # Refresh package lists before installing apps, to minimize the risk of
    # errors due to outdated package lists.
    check_debian_package_manager
    sudo apt-get update |& $PROGRAM_LOGS

    printf '\n%s' 'Install....'
    # Install kz deb package.
    check_debian_package_manager
    sudo apt-get "$install" --assume-yes "$kz_deb_local_file" |& $PROGRAM_LOGS
}


# This function checks if a Debian package manager is already running and waits
# for the next check if so.
function check_debian_package_manager() {
    local text='Wait for another package manager to finish...'

    while sudo  fuser                           \
                --silent                        \
                /var/cache/debconf/config.dat   \
                /var/{lib/{dpkg,apt/lists},cache/apt/archives}/lock*; do
        printf '%s\n' "$text" |& $PROGRAM_LOGS
        sleep 2
    done
}


# This function installs RPM package kz.
function process_kz_rpm_package() {
    local install='install'
    local kz_rpm_site_file=''
    local packages_url='https://karelzimmer.nl/assets/packages'

    if $OPTION_DEV; then
        kz_rpm_site_file=$packages_url/kz-dev-4.2.1-1.noarch.rpm
    else
        kz_rpm_site_file=$packages_url/kz-4.2.1-1.noarch.rpm
    fi

    if type kz &> /dev/null; then
        install='reinstall'
    fi

    printf '%s' 'Install...'
    printf '%s\n' "Installing $kz_rpm_site_file" |& $PROGRAM_LOGS
    # Install kz rpm package.
    sudo dnf "$install" --assumeyes "$kz_rpm_site_file" |& $PROGRAM_LOGS
}


# This function controls the termination of the script.
function term() {
    local text=''

    text="
===============================================================================

"

    if $OPTION_DEV; then
        text+="    $BOLD$(gettext \
"Please note: the development version of the kz package is installed")\
$NORMAL\n\n"
    fi

    text+="    $(gettext "Package kz has been successfully installed.")

    $(gettext \
"Now follow the steps as described in the Checklist installation.")

    $(gettext \
"Checklist installation can be found on https://karelzimmer.nl/en.")"
    if [[ -n ${DISPLAY-} ]]; then
        text+="

    $(gettext "Type 'exit' to close this window.")"
    fi
    text+="

===============================================================================
"
    printf '%b' "$text"

    exit 0
}


# #############################################################################
# Main
# #############################################################################

init "$@"
process
term
