#!/usr/bin/env bash
# shellcheck shell=bash
# #############################################################################
# SPDX-FileComment: Download and install Debian or RPM package kz
#
# SPDX-FileCopyrightText: Karel Zimmer <info@karelzimmer.nl>
# SPDX-License-Identifier: CC0-1.0
# #############################################################################


# #############################################################################
# Imports
# #############################################################################

export TEXTDOMAIN='kz'
export TEXTDOMAINDIR='/usr/share/locale'
source /usr/bin/gettext.sh


# #############################################################################
# Constants
# #############################################################################

readonly PROGRAM_NAME='kz-get'

readonly USAGE='kz get [-d|--dev]
       [-h|--help] [-m|--manual] [-u|--usage] [-v|--version]
       [-D|--debug]

wget karelzimmer.nl/getkz
bash getkz [-d|--dev]
           [-h|--help] [-m|--manual] [-u|--usage] [-v|--version]
           [-D|--debug]'

readonly HELP=$USAGE

readonly OPTIONS_SHORT='dhmuvD'
readonly OPTIONS_LONG='dev,help,manual,usage,version,debug'

# List NORMAL last here so that -x doesn't bork the display.
readonly BOLD='\033[1m'
readonly GREEN=$BOLD'\033[32m'
readonly RED=$BOLD'\033[31m'
readonly NORMAL='\033[0m'


# #############################################################################
# Globals
# #############################################################################

declare OPTION_DEV=false
declare OPTION_DEBUG=false


# #############################################################################
# Functions
# #############################################################################

# This function performs initial actions.
function init() {
    # Script-hardening.
    set -o errexit
    set -o errtrace
    set -o nounset
    set -o pipefail
}


# This function performs the script actions, such as checking the input.
function process() {
    check_input "$@"

    if ! $OPTION_DEBUG; then
        # Clean up temporary files if not in debug mode.
        trap 'rm --force getkz* /tmp/kz-*.deb' EXIT
    fi

    become_check || exit 0
    if grep --quiet --regexp='debian' /etc/os-release; then
        install_deb_package
    elif grep --quiet --regexp='rhel' /etc/os-release; then
        install_rpm_package
    else
        printf "$RED%b$NORMAL\n" "$(gettext 'fatal: unknown os release')" >&2
        exit 1
    fi
}


# This function checks the script input.
function check_input() {
    local parsed=''

    parsed=$(
        getopt  --alternative                       \
                --options       "$OPTIONS_SHORT"    \
                --longoptions   "$OPTIONS_LONG"     \
                --name          "$PROGRAM_NAME"     \
                --              "$@"
        ) || {
            printf '%s\n' "$USAGE" >&2
            exit 1
        }
    eval set -- "$parsed"
    unset parsed

    process_options "$@"
}

# This function handles the script options and arguments.
function process_options() {
    while true; do
        case $1 in
            -d | --dev )
                OPTION_DEV=true
                shift
                ;;
            -h | --help )
                printf '%s\n' "$HELP"
                exit 0
                ;;
            -m | --manual )
                if [[ -n ${DISPLAY-} ]]; then
                    yelp man:"$PROGRAM_NAME" 2> /dev/null
                else
                    man "$PROGRAM_NAME"
                fi
                exit 0
                ;;
            -u | --usage )
                printf '%s\n' "$USAGE"
                exit 0
                ;;
            -v | --version )
                printf '%s\n' "$PROGRAM_NAME 4.2.1"
                exit 0
                ;;
            -D | --debug )
                OPTION_DEBUG=true
                set -o verbose
                set -o xtrace
                shift
                ;;
            -- )
                shift
                break
                ;;
            * )
                printf  "$RED%s$NORMAL\n"   \
                        "$PROGRAM_NAME: getopt: internal error" >&2
                exit 1
            ;;
        esac
    done

    if [[ -n $* ]]; then
        printf '%s\n' "$USAGE" >&2
        exit 1
    fi
}


# This function checks if the user is allowed to become root and returns 0 if
# so, otherwise returns 1 with descriptive message.
function become_check() {
    if [[ $UID -eq 0 ]]; then
        return 0
    elif groups "$USER" | grep --quiet --regexp='sudo' --regexp='wheel'; then
        return 0
    else
        printf  "$GREEN%b$NORMAL\n"  \
                "$(gettext 'Already performed by the administrator.')" >&2
        return 1
    fi
}


# This function downloads and installs Debian package kz.
function install_deb_package() {
    local kz_deb_local_file=''
    local kz_deb_site_file=''
    local packages_url='https://karelzimmer.nl/assets/packages'
    local reinstall=''

    if $OPTION_DEV; then
        kz_deb_site_file=$packages_url/kz-dev_4.2.1-1_all.deb
        kz_deb_local_file=$(mktemp -t "kz-dev-XXXXXXXXXX.deb")
    else
        kz_deb_site_file=$packages_url/kz_4.2.1-1_all.deb
        kz_deb_local_file=$(mktemp -t "kz-XXXXXXXXXX.deb")
    fi

    if type kz &> /dev/null; then
        reinstall='--reinstall'
    else
        reinstall=''
    fi

    sudo true
    printf '%b\n' "$BOLD$(gettext 'DOWNLOAD') -- 1/3$NORMAL"
    wget --output-document="$kz_deb_local_file" "$kz_deb_site_file"
    # Prevent the message:
    # ...file '/tmp/kz-get-....deb' couldn't be accessed by user '_apt'.
    chmod o+r "$kz_deb_local_file"

    # Refresh package lists before installing apps, to minimize the risk of
    # errors due to outdated package lists.
    printf '%b\n' "$BOLD$(gettext 'UPDATE') -- 2/3$NORMAL"
    check_debian_package_manager
    sudo apt-get update
    printf '\n'

    # Install kz package.
    printf '%b\n' "$BOLD$(gettext 'INSTALL') -- 3/3$NORMAL"
    check_debian_package_manager
    sudo    DEBIAN_FRONTEND=noninteractive  \
            apt-get                         \
            install                         \
            --quiet                         \
            --quiet                         \
            "$reinstall"                    \
            "$kz_deb_local_file"
}


# This function checks if a Debian package manager is already running and waits
# for the next check if so.
function check_debian_package_manager() {
    local text=''

    text=$BOLD$(gettext 'Wait for another package manager to finish...')$NORMAL

    while sudo  fuser                           \
                --silent                        \
                /var/cache/debconf/config.dat   \
                /var/{lib/{dpkg,apt/lists},cache/apt/archives}/lock*; do
        printf '%s\n' "$text"
        sleep 2
    done
}


# This function installs RPM package kz.
function install_rpm_package() {
    local install=''
    local kz_rpm_site_file=''
    local packages_url='https://karelzimmer.nl/assets/packages'

    if $OPTION_DEV; then
        kz_rpm_site_file=$packages_url/kz-dev-4.2.1-1.noarch.rpm
    else
        kz_rpm_site_file=$packages_url/kz-4.2.1-1.noarch.rpm
    fi

    if type kz &> /dev/null; then
        install='reinstall'
    else
        install='install'
    fi

    # Refresh package lists before installing apps, to minimize the risk of
    # errors due to outdated package lists.
    printf '%b\n' "$BOLD$(gettext 'UPDATE') -- 1/2$NORMAL"
    sudo dnf check-update || true
    printf '\n'

    # Install kz package.
    printf '%b\n' "$BOLD$(gettext 'INSTALL') -- 2/2$NORMAL"
    sudo dnf "$install" --assumeyes "$kz_rpm_site_file"
}


# This function controls the termination of the script.
function term() {
    local text=''
    local separator_line=''

    separator_line=$(eval printf '=%.0s' '{1..80}')
    text="\n$separator_line\n\n"

    if $OPTION_DEV; then
        text+="$RED$(gettext "Please note: the development version of the kz \
package is installed")$NORMAL\n"
    fi

    text+="$(gettext "Package kz has been successfully installed.

Now follow the steps as described in the Checklist installation.

Checklist installation can be found on https://karelzimmer.nl/en.")"
    if [[ -n ${DISPLAY-} ]]; then
        text+="

$(gettext "Type 'exit' to close this window.")"
    fi
    printf '%b\n' "$text"

    exit 0
}


# #############################################################################
# Main
# #############################################################################

function main() {
    init    "$@"
    process "$@"
    term
}

main "$@"
