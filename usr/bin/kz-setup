#!/usr/bin/env bash
# shellcheck source=kz_common.sh
# #############################################################################
# SPDX-FileComment: Set up apps and change user settings
#
# SPDX-FileCopyrightText: Karel Zimmer <info@karelzimmer.nl>
# SPDX-License-Identifier: CC0-1.0
# #############################################################################


# #############################################################################
# Imports
# #############################################################################

source kz_common.sh as kz


# #############################################################################
# Constants
# #############################################################################

readonly PROGRAM_NAME='kz-setup'
PROGRAM_DESC=$(gettext 'Set up apps and change user settings')
readonly PROGRAM_DESC
readonly PROGRAM_LOGS="systemd-cat --identifier=$PROGRAM_NAME"

USAGE=$(
gettext 'Usage: kz setup [-b|--browse] [-c|--cat] [-f|--file <file>]...
                [-g|--gui] [-l|--list] [-r|--reset] [-s|--select]
                [-h|--help] [-m|--manual] [-u|--usage] [-v|--version]
                [-D|--debug] [--] [<app>...]'
    )
readonly USAGE

HELP="$(gettext 'Usage: kz setup [<options>] [--] [<arguments>]')

$PROGRAM_DESC.

$(gettext 'Options:')
$(gettext "  Mandatory arguments to long options are mandatory for short \
options too.")

$(gettext '  -b, --browse   browse settings files')
$(gettext '  -c, --cat      show contents of command file')
$(gettext "  -f, --file <file>
                 process specified settings files")
$(gettext '  -g, --gui      run in graphical mode')
$(gettext '  -l, --list     show available apps')
$(gettext '  -r, --reset    set apps on default values')
$(gettext '  -s, --select   select apps')
$(gettext '  -h, --help     show this help text')
$(gettext '  -m, --manual   show manual page')
$(gettext '  -u, --usage    show a short usage summary')
$(gettext '  -v, --version  show program version')
$(gettext '  -D, --debug    show debug information')

$(gettext 'Arguments:')
$(gettext '  <app>          process specified apps')"
readonly HELP

readonly OPTIONS_SHORT='bcf:glrshmuvD'
readonly OPTIONS_LONG="browse,cat,file:,gui,list,reset,select,help,manual,\
usage,version,debug"


# #############################################################################
# Globals
# #############################################################################

declare -A FAILED_APPS=()
declare ERROR_LOG=''
declare LOGOUT=false
declare GUI_MODE=false
declare TUI_MODE=true
declare OPTION_RESET=false
declare OPTION_SELECT=false


# #############################################################################
# Functions
# #############################################################################

# This function performs the script actions.
function process() {
    local -A app_arguments=()
    local -a settings_files=()
    local -i settings_file_num=0
    local argument_app=false
    local command_file=''
    local err_flag=false
    local option_browse=false
    local option_cat=false
    local option_file=false
    local option_list=false
    local reset='RESET'
    local settings_file_decrypted=''
    local settings_file_default=/usr/bin/$PROGRAM_NAME.sh
    local settings_file=''
    local setup='SETUP'
    local text=''

    check_input "$@"

    if ! $option_file; then
        settings_files[++settings_file_num]=$settings_file_default
        # Decrypt GPG-encrypted settings file.
        settings_file_decrypted=\
$(mktemp -t "$PROGRAM_NAME-decrypted-XXXXXXXXXX.sh")
        gpg --decrypt                       \
            /usr/bin/kz-setup.sh.gpg        \
            2> >($PROGRAM_LOGS)             \
            > "$settings_file_decrypted"
        settings_files[++settings_file_num]=$settings_file_decrypted
    fi

    for settings_file in "${settings_files[@]}"; do
        if ! [[ -f $settings_file ]]; then
            text=$(eval_gettext "Settings file '\$settings_file' not found.")
            kz.errmsg "$text"
            err_flag=true
        fi
    done
    if $err_flag; then
        exit 1
    fi

    if $option_browse; then
        process_option_browse
        exit 0
    fi

    if $option_list; then
        process_option_list
        exit 0
    fi

    command_file=$(mktemp -t "$PROGRAM_NAME-commands-XXXXXXXXXX.sh")

    if $OPTION_SELECT; then
        process_option_select
    fi

    if $argument_app; then
        process_argument_app
    else
        process_settings_files_by_hostname
    fi

    if $option_cat; then
        process_option_cat
        exit 0
    fi

    setup_apps
}


# This function checks the script input.
function check_input() {
    local parsed=''
    local program_name=${PROGRAM_NAME/kz-/kz }

    parsed=$(
        getopt  --alternative                       \
                --options       "$OPTIONS_SHORT"    \
                --longoptions   "$OPTIONS_LONG"     \
                --name          "$program_name"     \
                --              "$@"
        )   ||  {
                    kz.infomsg "$USAGE"
                    exit 1
                }
    eval set -- "$parsed"
    unset parsed

    process_options "$@"
}


# This function handles the script options and arguments.
function process_options() {
    local program_name=${PROGRAM_NAME/kz-/kz }
    local text=''

    while true; do
        case $1 in
            -b | --browse )
                option_browse=true
                shift
                ;;
            -c | --cat )
                option_cat=true
                shift
                ;;
            -f | --file )
                option_file=true
                settings_files[++settings_file_num]=$2
                shift 2
                ;;
            -g | --gui )
                if [[ -z ${DISPLAY-} ]]; then
                    text="$program_name: $1: $(gettext "no desktop \
environment available")"
                    kz.infomsg "$text"
                    exit 1
                fi
                GUI_MODE=true
                TUI_MODE=false
                shift
                ;;
            -l | --list )
                option_list=true
                shift
                ;;
            -r | --reset )
                OPTION_RESET=true
                setup='RESET'
                reset='SETUP'
                shift
                ;;
            -s | --select )
                OPTION_SELECT=true
                shift
                ;;
            -h | --help )
                kz.process_option_help
                exit 0
                ;;
            -m | --manual )
                kz.process_option_manual
                exit 0
                ;;
            -u | --usage )
                kz.process_option_usage
                exit 0
                ;;
            -v | --version )
                kz.process_option_version
                exit 0
                ;;
            -D | --debug )
                set -o xtrace
                shift
                ;;
            -- )
                shift
                break
                ;;
            * )
                text="$PROGRAM_NAME: getopt: $(gettext 'internal error')"
                kz.errmsg "$text"
                exit 1
                ;;
        esac
    done

    if [[ -n $* ]]; then
        argument_app=true
        while [[ -n $* ]]; do
            app_arguments[$1]=$1
            shift
        done
    fi
}


# This function browses through the settings files.
function process_option_browse() {
    GUI_MODE=false
    less --no-init --quit-if-one-screen < <(cat "${settings_files[@]}" || true)
}


# This function shows the available apps from the settings files.
function process_option_list() {
    local apps=''
    local text=''

    GUI_MODE=false
    text=$(gettext 'The following apps are available:')
    apps=$(
        grep    "#[[:space:]]\+${setup}[[:space:]]\+"   \
                "${settings_files[@]}"                  |
        tr      --squeeze-repeats                       \
                '[:space:]'                             |
        cut     --delimiter=' '                         \
                --fields=3                              |
        sort    --unique                                |
        sed     --expression='s/^/    /'                || true
        )
    if [[ -n $apps ]]; then
        text+="
$apps"
        if [[ $setup = 'SETUP' ]]; then
            text+="

$(gettext 'Use "kz setup <app>..." to set up the apps.')
$(gettext "Use \"kz setup --cat <app>...\" to view the contents of the apps \
command file.")
$(gettext "Use  \"kz setup --cat\" to view the contents of the whole command \
file.")"
        else
            text+="

$(gettext 'Use "kz setup --reset <app>..." to reset the apps.')
$(gettext "Use \"kz setup --cat --reset <app>...\" to view the contents of \
the apps command file.")
$(gettext "Use \"kz setup --cat --reset\" to view the contents of the whole \
command file.")"
        fi
        text+="
$(gettext "Use \"kz setup --browse\" to view the contents of the default \
settings files.")"
    else
        text+="$(gettext '  0  No apps found.')

$USAGE"
    fi
    kz.infomsg "$text"
}


# This function processes apps selected via the graphical user interface (GUI)
# or text user interface (TUI).
function process_option_select() {
    local -a all_apps=()
    local -a choices=()
    local app=''
    local text=''
    local title=''

    title=$(gettext 'Set up apps')
    text=$(gettext 'Select apps to set up:')

    readarray   all_apps < <(
        grep    "#[[:space:]]\+${setup}[[:space:]]\+"   \
                "${settings_files[@]}"                  |
        tr      --squeeze-repeats                       \
                '[:space:]'                             |
        cut     --delimiter=' '                         \
                --fields=3                              |
        sort    --unique
        )

    if $GUI_MODE; then
        for app in "${all_apps[@]}"; do
            choices+=('false' "$app")
        done
        # No array is needed because the app name does not contain spaces.
        selected_apps=$(
            zenity      --list                              \
                        --checklist                         \
                        --separator ' '                     \
                        --height    400                     \
                        --title     "$title"                \
                        --text      "$text"                 \
                        --ok-label  "$(gettext 'Continue')" \
                        --column    "$(gettext 'SEL')"      \
                        --column    "$(gettext 'APP')"      \
                        "${choices[@]}"                     \
                        2> /dev/null                        || true
            )
    else
        for app in "${all_apps[@]}"; do
            choices+=("$app" 'off')
        done
        # No array is needed because the app name does not contain spaces.
        selected_apps=$(
            whiptail    --ok-button "$(gettext 'Continue')" \
                        --noitem                            \
                        --backtitle "$PROGRAM_NAME"         \
                        --title     "$title"                \
                        --checklist "$text"                 \
                        20 40 12                            \
                        "${choices[@]}"                     \
                        2>&1 >/dev/tty                      |
            sed         's/"//g'                            || true
            )
    fi
    if [[ -z $selected_apps ]]; then
        text=$(gettext 'No apps selected.')
        kz.infomsg "$text"
        exit 0
    fi

    argument_app=true
    for selected_app in $selected_apps; do
        app_arguments[$selected_app]=$selected_app
    done
}


# This function processes argument <app>.
function process_argument_app() {
    local app_argument=''
    local err_flag=false

    for app_argument in "${app_arguments[@]}"; do
        process_settings_files_by_app_argument
    done

    if $err_flag; then
        exit 1
    fi
}


# This function generates the command file from the settings file and filters
# by <app>.
function process_settings_files_by_app_argument() {
    local app_match=false
    local setup_record=''
    local no_app_match=true
    local text=''

    while read -r setup_record; do
        case $setup_record in
            '#'[[:space:]]*${setup}[[:space:]]*${app_argument}[[:space:]]* )
                # Add matching app record to command file.
                app_match=true
                no_app_match=false
                printf '%s\n' "$setup_record" >> "$command_file"
                ;;
            '#'[[:space:]]*${setup}[[:space:]]* | \
            '#'[[:space:]]*${reset}[[:space:]]* )
                # Skip mismatched app record.
                app_match=false
                ;;
            * )
                if $app_match; then
                    # Add record to command file.
                    printf '%s\n' "$setup_record" >> "$command_file"
                fi
                ;;
        esac
    done < <(cat "${settings_files[@]}")

    if $no_app_match; then
        err_flag=true
        text=$(eval_gettext "App '\$app_argument' not found.")
        kz.errmsg "$text"
    fi
}


# This function generates the command file from the settings file and filters
# by host.
function process_settings_files_by_hostname() {
    local host_match=false
    local setup_record=''

    while read -r setup_record; do
        case $setup_record in
            '#'[[:space:]]*${setup}[[:space:]]*'*' | \
            '#'[[:space:]]*${setup}[[:space:]]*$HOSTNAME* )
                # Add matching app record to command file.
                host_match=true
                printf '%s\n' "$setup_record" >> "$command_file"
                ;;
            '#'[[:space:]]*${setup}[[:space:]]* | \
            '#'[[:space:]]*${reset}[[:space:]]* )
                # Skip mismatched app record.
                host_match=false
                ;;
            * )
                if $host_match; then
                    # Add record to command file.
                    printf '%s\n' "$setup_record" >> "$command_file"
                fi
                ;;
        esac
    done < <(cat "${settings_files[@]}")
}


# This function displays the contents of the command file.
function process_option_cat() {
    GUI_MODE=false
    less --no-init --quit-if-one-screen "$command_file"
}


# This function starts setting up the apps.
function setup_apps() {
    local -i app_tot_num=0
    local text=''
    local title=''

    app_tot_num=$(
        grep    --count                                 \
                "#[[:space:]]\+${setup}[[:space:]]\+"   \
                "$command_file"                         || true
                )
    if [[ $app_tot_num -eq 0 ]]; then
        text=$(gettext 'No commands to execute.' )
        kz.infomsg "$text"
        exit 0
    fi

    ERROR_LOG=$(mktemp -t "$PROGRAM_NAME-error-XXXXXXXXXX.log")
    text="** $ERROR_LOG (stderr)"
    printf '%s\n' "$text" > "$ERROR_LOG"

    title=$(gettext 'Set up apps')
    text=$(gettext 'Preparing set up')

    if $GUI_MODE; then
        # With '|& zenity --progress' global variables from called functions
        # are not passed, hence the process substitution with '> >(zenity...)'.
        process_command_file > >(
            zenity  --progress              \
                    --pulsate               \
                    --auto-close            \
                    --no-cancel             \
                    --width     700         \
                    --height    50          \
                    --title     "$title"    \
                    --text      "$text"     2> /dev/null
            )
    else
        process_command_file
    fi
}


# This function reads commands from the command file for further processing.
function process_command_file() {
    local -i app_seq_num=0
    local app_line=false
    local app_name_line=''
    local app_name=''
    local command_record=''
    local text=''

    if $TUI_MODE; then
        text="$(gettext 'NUM/TOT  APP')
         $(gettext 'COMMAND')..."
        text="$(gettext 'NUM/TOT  APP')
         $(gettext 'COMMAND')..."
        TERM=ansi                               \
        whiptail    --backtitle "$PROGRAM_NAME" \
                    --title     "$title"        \
                    --infobox   "$text"         \
                    10 78
    fi

    while read -r command_record; do
        case $command_record in
            '' )
                # Skip empty record.
                continue
                ;;
            '#'[[:space:]]*${setup}[[:space:]]* )
                # App record.
                app_name=$(
                    printf '%s\n' "$command_record"     |
                    tr --squeeze-repeats '[:space:]'    |
                    cut --delimiter=' ' --fields=3
                    )
                (( ++app_seq_num ))
                app_line=true
                printf  -v app_name_line    \
                        "%3d/%-3d  %s"      \
                        "$app_seq_num"      \
                        "$app_tot_num"      \
                        "$app_name"
                # To corrolate possible error messages with app name.
                printf ' \n%s\n' "-- App $app_name" >> "$ERROR_LOG"
                ;;
            '#'* )
                # Skip comment record.
                continue
                ;;
            * )
                # Process command record.
                execute_command "$command_record"
                app_line=false
                ;;
        esac
    done < "$command_file"
}


# This function reports and executes a command from the command file.
function execute_command() {
    local cmd=$1

    if $app_line; then
        kz.logmsg "$app_name_line"
    fi
    kz.logmsg "$cmd"

    if $GUI_MODE; then
        printf '%s\n' "#$app_name_line\n\n$cmd"
    else
        TERM=ansi                                                   \
        whiptail    --backtitle "$PROGRAM_NAME"                     \
                    --title     "$title"                            \
                    --infobox   "$app_name_line\n\n         $cmd"   \
                    10 78
    fi

    eval    "$cmd"              \
            1> >($PROGRAM_LOGS) \
            2>> "$ERROR_LOG"    || FAILED_APPS[$app_name]=$app_name
}


# This function controls the termination of the script.
function term() {
    local program_name=${PROGRAM_NAME/kz-/kz }
    local text=''
    local title=''

    # Error-log (stderr) also to the main log.
    kz.logmsg '---------------------------------------------------------------'
    text="** $ERROR_LOG (stderr)"
    printf '%s\n%s\n' ' ' "$text" >> "$ERROR_LOG"
    printf '%s' "$(<"$ERROR_LOG")" |& $PROGRAM_LOGS
    kz.logmsg '---------------------------------------------------------------'

    if [[ -n ${FAILED_APPS[*]} ]]; then
        title="$PROGRAM_DESC $(gettext 'error messages')"
        text="$(gettext "The set up of the following apps contains errors:")
${FAILED_APPS[*]}

$(gettext 'Actions to take:')
$(gettext 'Check the error messages after this.')
$(gettext 'Try to set up/reset the apps again.')"
        kz.errmsg "$text"

        if $GUI_MODE; then
            zenity      --text-info                 \
                        --filename="$ERROR_LOG"     \
                        --width     700             \
                        --height    500             \
                        --title     "$title"        \
                        2> /dev/null                || true
        else
            whiptail    --backtitle "$PROGRAM_NAME" \
                        --title     "$title"        \
                        --textbox   "$ERROR_LOG"    \
                        25 80
        fi
    fi

    text=$(gettext "Apps set up completed.")
    if $OPTION_RESET; then
        text=$(gettext "Apps reset completed.")
    fi

    if $LOGOUT; then

        if [[ -n ${DISPLAY-} ]]; then
            text+="

$(gettext "You will now be logged out of the computer to finish setting up \
the apps and changing user settings.")"
        else
            text+="

$(gettext "Type 'logout' to log out of the computer to finish setting up the \
apps and changing user settings.")"
        fi
        kz.infomsg "$text"

        if [[ -n ${DISPLAY-} ]]; then
            # A GUI is available.
            if type cinnamon-session |& $PROGRAM_LOGS; then
                # Cinnamon.
                cinnamon-session-quit --logout --force
            elif type gnome-session |& $PROGRAM_LOGS; then
                # GNOME.
                gnome-session-quit --logout --no-prompt
            elif type lxsession |& $PROGRAM_LOGS; then
                # LXDE.
                lxde-logout
            else
                text=$(gettext 'Log out of the computer yourself.')
                kz.infomsg "$text"
            fi
        fi
    else
        kz.infomsg "$text"
    fi

    exit 0
}


# #############################################################################
# Main
# #############################################################################

function main() {
    kz.init "$@"
    process "$@"
    term
}

main "$@"
