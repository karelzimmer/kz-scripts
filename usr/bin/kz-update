# #############################################################################
# Imports
# #############################################################################

import getopt
import gettext
import kz_common as kz
import subprocess
import sys
import time

gettext.bindtextdomain('kz', '/usr/share/locale')
gettext.textdomain('kz')
_ = gettext.gettext


# #############################################################################
# Constants
# #############################################################################

PROGRAM_NAME: str = 'kz-update'
PROGRAM_DESC: str = _('Update and cleanup the system')

USAGE: str = _(
    "Usage: kz update [-h|--help] [-m|--manual] [-u|--usage] [-v|--version]"
    )

HELP_LINES: list[str] = [
    _('Usage: kz update [<options>]'),
    '',
    f'{PROGRAM_DESC}.',
    '',
    _('Options:'),
    _('  -h, --help     show this help text'),
    _('  -m, --manual   show manual page'),
    _('  -u, --usage    show a short usage summary'),
    _('  -v, --version  show program version'),
    ]
HELP: str = '\n'.join(HELP_LINES)
del HELP_LINES

OPTIONS_SHORT: str = 'hmuv'
OPTIONS_LONG: list[str] = ['help', 'manual', 'usage', 'version']


# #############################################################################
# Globals
# #############################################################################


# #############################################################################
# Functions
# #############################################################################

def process() -> None:
    """
    This function performs the script actions.
    """
    check_sudo: str = 'sudo --validate'
    check_debian: str = "grep --quiet 'debian' /etc/os-release"
    check_rhel: str = r"grep --quiet 'rhel\|fedora' /etc/os-release"
    text: str

    check_input(PROGRAM_NAME, PROGRAM_DESC, USAGE, HELP)
    try:
        subprocess.run(check_sudo, executable='bash', shell=True, check=True)
    except KeyboardInterrupt:
        text = _('Program {} has been interrupted.').format(PROGRAM_NAME)
        kz.errmsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        kz.term(PROGRAM_NAME, 130)
    except subprocess.CalledProcessError as exc:
        text = str(exc)
        kz.logmsg(PROGRAM_NAME, text)
        text = _('Program {} encountered an error.').format(PROGRAM_NAME)
        kz.errmsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        kz.term(PROGRAM_NAME, exc.returncode)

    if subprocess.run(check_debian, executable='bash',
                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                      shell=True).returncode == 0:
        text = f'{kz.BOLD}{_('Update...')}{kz.NORMAL}'
        kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        perform_update_debs()
        text = f'{kz.BOLD}{_('Upgrade...')}{kz.NORMAL}'
        kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        perform_upgrade_debs()
        perform_update_snaps()
        perform_update_flatpaks()
        perform_update_extensions()
        text = f'{kz.BOLD}{_('Cleanup...')}{kz.NORMAL}'
        kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        perform_cleanup_debs()
    elif subprocess.run(check_rhel, executable='bash',
                        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                        shell=True).returncode == 0:
        text = f'{kz.BOLD}{_('Upgrade...')}{kz.NORMAL}'
        kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        perform_upgrade_rpms()
        perform_update_snaps()
        perform_update_flatpaks()
        perform_update_extensions()
        text = f'{kz.BOLD}{_('Cleanup...')}{kz.NORMAL}'
        kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        perform_cleanup_rpms()
    else:
        text = _('fatal: unknown os release')
        kz.errmsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        kz.term(PROGRAM_NAME, 1)


def check_input(PROGRAM_NAME: str, PROGRAM_DESC: str, USAGE: str,
                HELP: str) -> None:
    """
    This function checks the script input.
    """
    args: list[str] = []
    err: BaseException
    opts: list[tuple[str, str]] = []
    program_name: str = PROGRAM_NAME.replace('kz-', 'kz ')
    text: str

    try:
        opts, args = getopt.gnu_getopt(sys.argv[1:], OPTIONS_SHORT,
                                       OPTIONS_LONG)
    except getopt.error as err:
        text = f'{program_name}: {err}\n{USAGE}'
        kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        kz.term(PROGRAM_NAME, 1)

    process_options(PROGRAM_NAME, PROGRAM_DESC, USAGE, HELP, opts, args)


def process_options(PROGRAM_NAME: str, PROGRAM_DESC: str, USAGE: str,
                    HELP: str, opts: list[tuple[str, str]],
                    args: list[str]) -> None:
    """
    This function handles the script options and arguments.
    """
    arg: str = ''
    opt: str = ''
    program_name: str = PROGRAM_NAME.replace('kz-', 'kz ')
    text: str

    for opt, arg in opts:
        if opt in ('-h', '--help'):
            kz.process_option_help(PROGRAM_NAME, PROGRAM_DESC, HELP)
            kz.term(PROGRAM_NAME, 0)
        elif opt in ('-m', '--manual'):
            kz.process_option_manual(PROGRAM_NAME, PROGRAM_DESC)
            kz.term(PROGRAM_NAME, 0)
        elif opt in ('-u', '--usage'):
            kz.process_option_usage(PROGRAM_NAME, PROGRAM_DESC, USAGE)
            kz.term(PROGRAM_NAME, 0)
        elif opt in ('-v', '--version'):
            kz.process_option_version(PROGRAM_NAME, PROGRAM_DESC)
            kz.term(PROGRAM_NAME, 0)
        else:
            text = f"{PROGRAM_NAME}: getopt: {_('internal error')}"
            kz.errmsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
            kz.term(PROGRAM_NAME, 1)

    if args:
        text = (
            f"{program_name}: {' '.join(args)}: "
            f"{_('arguments are not allowed')}\n{USAGE}"
            )
        kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        kz.term(PROGRAM_NAME, 1)


def perform_update_debs() -> None:
    """
    This function updates installed Debian packages.
    """
    command: str

    command = 'sudo apt-get update'
    perform_command(command)


def perform_upgrade_debs() -> None:
    """
    This function upgrades installed Debian packages.
    """
    command: str

    command = 'sudo apt-get --assume-yes upgrade'
    perform_command(command)


def perform_update_snaps() -> None:
    """
    This function updates installed Snap packages.
    """
    command: str

    if subprocess.run('type snap', executable='bash',
                      stdout=subprocess.DEVNULL,
                      stderr=subprocess.DEVNULL,
                      shell=True,).returncode == 0:
        command = 'sudo snap refresh'
        perform_command(command)


def perform_update_flatpaks() -> None:
    """
    This function updates installed Flatpak packages.
    """
    command: str

    if subprocess.run('type flatpak', executable='bash',
                      stdout=subprocess.DEVNULL,
                      stderr=subprocess.DEVNULL,
                      shell=True,).returncode == 0:
        command = 'sudo flatpak --assumeyes update'
        perform_command(command)


def perform_update_extensions() -> None:
    """
    This function updates all enabled extensions.
    """
    command: str

    if subprocess.run('type gext', executable='bash',
                      stdout=subprocess.DEVNULL,
                      stderr=subprocess.DEVNULL,
                      shell=True,).returncode == 0:
        command = 'gext update'
        perform_command(command)


def perform_upgrade_rpms() -> None:
    """
    This function upgrades installed RPM packages.
    """
    command: str

    command = 'sudo dnf upgrade --assumeyes --refresh'
    perform_command(command)


def perform_cleanup_debs() -> None:
    """
    This function performs a Debian packages cleanup.
    """
    command: str

    command = 'sudo apt-get autoclean'
    perform_command(command)

    command = 'sudo apt-get autoremove --assume-yes'
    perform_command(command)


def perform_cleanup_rpms() -> None:
    """
    This function performs a RPM packages cleanup.
    """
    command: str

    command = 'sudo dnf clean all'
    perform_command(command)

    command = 'sudo dnf autoremove --assumeyes'
    perform_command(command)


def perform_command(command: str = '') -> None:
    """
    This function executes a Bash command.
    """
    exc: BaseException
    text: str

    text = f'{command}...'
    kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)

    check_debian_package_manager(PROGRAM_NAME, PROGRAM_DESC)
    try:
        subprocess.run(command, executable='bash', shell=True, check=True)
    except KeyboardInterrupt:
        text = _('Program {} has been interrupted.').format(PROGRAM_NAME)
        kz.errmsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        kz.term(PROGRAM_NAME, 130)
    except Exception as exc:
        text = str(exc)
        kz.logmsg(PROGRAM_NAME, text)
        text = _('Program {} encountered an error.').format(PROGRAM_NAME)
        kz.errmsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        kz.term(PROGRAM_NAME, 1)
    print()  # Print a newline after the command output.


def check_debian_package_manager(PROGRAM_NAME: str, PROGRAM_DESC: str) -> int:
    """
    This function checks if a Debian package manager is already running and
    waits for the next check if so.
    """
    check_debian_package_manager: str = 'pkexec /usr/bin/kz_common-pkexec'
    check_rhel: str = r"grep --quiet --regexp='rhel\|fedora' /etc/os-release"
    text: str = 'Wait for another package manager to finish...'

    if subprocess.run(check_rhel, executable='bash',
                      stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                      shell=True).returncode == 0:
        return 0

    while True:
        try:
            subprocess.run(check_debian_package_manager, executable='bash',
                           shell=True, check=True)
        except Exception:
            break
        else:
            kz.logmsg(PROGRAM_NAME, text)
            time.sleep(1)

    return 0


def term() -> None:
    """
    This function controls the termination of the script.
    """
    text: str

    text = f'{kz.GREEN}{_('Complete!')}{kz.NORMAL}'
    kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
    kz.term(PROGRAM_NAME, 0)


# #############################################################################
# Main
# #############################################################################

kz.init(PROGRAM_NAME)
process()
term()
