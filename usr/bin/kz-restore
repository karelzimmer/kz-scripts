#!/usr/bin/env bash
# shellcheck source=kz_common.sh
# #############################################################################
# SPDX-FileComment: Restore a backup copy of the Home folder
#
# SPDX-FileCopyrightText: Karel Zimmer <info@karelzimmer.nl>
# SPDX-License-Identifier: CC0-1.0
# #############################################################################


# #############################################################################
# Imports
# #############################################################################

source kz_common.sh as kz


# #############################################################################
# Constants
# #############################################################################

readonly PROGRAM_NAME='kz-restore'
PROGRAM_DESC=$(gettext 'Restore a backup copy of the Home folder')
readonly PROGRAM_DESC
readonly PROGRAM_LOGS="systemd-cat --identifier=$PROGRAM_NAME"

USAGE=$(gettext 'Usage: kz restore [-g|--gui] [-s|--source <directory>]
                  [-h|--help] [-m|--manual] [-u|--usage] [-v|--version]
                  [-D|--debug]')
readonly USAGE

HELP="$(gettext 'Usage: kz restore [<options>]')

$PROGRAM_DESC.

$(gettext 'Options:')
$(gettext "  Mandatory arguments to long options are \
mandatory for short options too.")

$(gettext '  -g, --gui      run in graphical mode')
$(gettext '  -s, --source <directory>
                 use backup in specified directory')
$(gettext '  -h, --help     show this help text')
$(gettext '  -m, --manual   show manual page')
$(gettext '  -u, --usage    show a short usage summary')
$(gettext '  -v, --version  show program version')
$(gettext '  -D, --debug    show debug information')"
readonly HELP

readonly OPTIONS_SHORT='gs:hmuvD'
readonly OPTIONS_LONG='gui,source:,help,manual,usage,version,debug'


# #############################################################################
# Globals
# #############################################################################

declare -i RESTORE_RC=0
declare ERROR_LOG=''
declare GUI_MODE=false
declare SOURCE=''
declare TUI_MODE=true


# #############################################################################
# Functions
# #############################################################################

# This function performs the script actions.
function process() {
    local medium=''
    local option_source=false
    local source_argument=''

    check_input "$@"
    check_source
    restore_backup
    restore_settings
}


# This function checks the script input.
function check_input() {
    local parsed=''
    local program_name=${PROGRAM_NAME/kz-/kz }

    parsed=$(
        getopt  --alternative                       \
                --options       "$OPTIONS_SHORT"    \
                --longoptions   "$OPTIONS_LONG"     \
                --name          "$program_name"     \
                --              "$@"
        )   ||  {
                    kz.infomsg "$USAGE"
                    exit 1
                }
    eval set -- "$parsed"
    unset parsed

    process_options "$@"
}


# This function handles the script options and arguments.
function process_options() {
    local program_name=${PROGRAM_NAME/kz-/kz }
    local text=''

    while true; do
        case $1 in
            -g | --gui )
                if [[ -z ${DISPLAY-} ]]; then
                    text="$program_name: $1: $(gettext "no desktop \
environment available")"
                    kz.infomsg "$text"
                    exit 1
                fi
                GUI_MODE=true
                TUI_MODE=false
                shift
                ;;
            -s | --source )
                if $option_source; then
                    text="$program_name: $1 $2: $(gettext 'too many options')
$USAGE"
                    kz.infomsg "$text"
                    exit 1
                fi
                option_source=true
                source_argument=$2
                shift 2
                ;;
            -h | --help )
                kz.process_option_help
                exit 0
                ;;
            -m | --manual )
                kz.process_option_manual
                exit 0
                ;;
            -u | --usage )
                kz.process_option_usage
                exit 0
                ;;
            -v | --version )
                kz.process_option_version
                exit 0
                ;;
            -D | --debug )
                set -o xtrace
                shift
                ;;
            -- )
                shift
                break
                ;;
            * )
                text="$PROGRAM_NAME: getopt: $(gettext 'internal error')"
                kz.errmsg "$text"
                exit 1
                ;;
        esac
    done

    if [[ -n $* ]]; then
        text="$program_name: $*: $(gettext 'arguments are not allowed')
$USAGE"
        kz.infomsg "$text"
        exit 1
    fi
}


# This function checks if the source is available.
function check_source() {
    local -a all_media=()
    local -a choices=()
    local program_name=${PROGRAM_NAME/kz-/kz }
    local selected_medium=''
    local text=''
    local title=''
    local usb_mount_point=/media/$USER

    if grep --quiet rhel /etc/os-release; then
        usb_mount_point=/run/media/$USER
    fi

    if $option_source; then
        if ! [[ -d $source_argument ]]; then
            text="$program_name: $source_argument: \
$(gettext 'directory does not exist')
$USAGE"
            kz.infomsg "$text"
            exit 1
        fi
        medium=$source_argument
    else
        medium=$(find "$usb_mount_point/"* -prune 2> /dev/null || true)
        if [[ -z $medium ]]; then
            text=$(gettext "No usb medium found.

Connect a usb medium.")
            kz.infomsg "$text"
            $GUI_MODE || kz.wait_for_enter
            medium=$(find "$usb_mount_point/"* -prune 2> /dev/null || true)
            if [[ -z $medium ]]; then
                kz.errmsg "$text"
                exit 1
            fi
        fi

        medium=$(find "$usb_mount_point/"* -prune || true)
        if [[ $(printf '%s\n' "$medium" | wc --lines) -gt 1 ]]; then

            title=$(gettext 'Restore backup')
            text=$(gettext 'Choose USB medium:')

            readarray all_media < <(find "$usb_mount_point/"* -prune)

            if $GUI_MODE; then
                for medium in "${all_media[@]}"; do
                    choices+=('false' "$medium")
                done
                # No array is needed, because only one can be selected.
                selected_medium=$(
                    zenity  --list                              \
                            --radiolist                         \
                            --separator ' '                     \
                            --height    400                     \
                            --title     "$title"                \
                            --text      "$text"                 \
                            --ok-label  "$(gettext 'Continue')" \
                            --column    "$(gettext 'SEL')"      \
                            --column    "$(gettext 'MEDIUM')"   \
                            "${choices[@]}"                     \
                            2> /dev/null                        || true
                    )
                if [[ -z $selected_medium ]]; then
                    text=$(gettext 'No USB medium selected.')
                    zenity  --info                  \
                            --width     600         \
                            --height    100         \
                            --title     "$title"    \
                            --text      "$text"     \
                            2> /dev/null            || true
                    exit 0
                fi
            else
                for medium in "${all_media[@]}"; do
                    choices+=("$medium" 'off')
                done
                # No array is needed, because only one can be selected.
                selected_medium=$(
                    whiptail    --ok-button "$(gettext 'Continue')" \
                                --noitem                            \
                                --backtitle "$PROGRAM_NAME"         \
                                --title     "$title"                \
                                --radiolist "$text"                 \
                                20 40 12                            \
                                "${choices[@]}"                     \
                                2>&1 >/dev/tty                      |
                    sed         's/"//g'                            || true
                    )
                if [[ -z $selected_medium ]]; then
                    text=$(gettext 'No USB medium selected.')
                    zenity  --info                  \
                            --width     600         \
                            --height    100         \
                            --title     "$title"    \
                            --text      "$text"     \
                            2> /dev/null            || true
                    exit 0
                fi
            fi
            medium=$selected_medium
        fi
    fi

    SOURCE=$medium/BACKUP-$USER@$HOSTNAME

    if ! [[ -d $SOURCE ]]; then
        text=$(eval_gettext "No BACKUP-\$USER@\$HOSTNAME found in \$medium.")
        kz.infomsg "$text"
        $GUI_MODE || kz.wait_for_enter
        if ! [[ -d $SOURCE ]]; then
            kz.errmsg "$text"
            exit 1
        fi
    fi
}


# This function restores the backup.
function restore_backup() {
    local text=''
    local title=''

    ERROR_LOG=$(mktemp -t "$PROGRAM_NAME-error-XXXXXXXXXX.log")
    text="** $ERROR_LOG (stderr)"
    printf '%s\n' "$text" > "$ERROR_LOG"

    title=$(gettext 'Restore backup')
    text=$(gettext 'Preparing restore (this can take a while)')
    kz.logmsg "$title"...

    if $GUI_MODE; then
        rsync   --archive               \
                --info=progress2        \
                "$SOURCE/"              \
                "$HOME/"                \
                2>> "$ERROR_LOG"        |
        stdbuf  --input=0               \
                --output=0              \
                --error=0               \
                tr '\r' '\n'            |
        stdbuf  --input=0               \
                --output=0              \
                --error=0               \
        sed     --expression='s/^/#/'   |
        zenity  --progress              \
                --auto-close            \
                --no-cancel             \
                --pulsate               \
                --width     600         \
                --height    50          \
                --title     "$title"    \
                --text      "$text"     \
                2> /dev/null            || RESTORE_RC=$?
    else
        text+='...'
        TERM=ansi
        rsync       --archive                       \
                    --info=progress2                \
                    "$SOURCE/"                      \
                    "$HOME/"                        \
                    2>> "$ERROR_LOG"                |
        stdbuf      --input=0                       \
                    --output=0                      \
                    --error=0                       \
                    tr '\r' '\n'                    |
        stdbuf      --input=0                       \
                    --output=0                      \
                    --error=0                       \
                    awk "{ print \$2 }"             |
        stdbuf      --input=0                       \
                    --output=0                      \
                    --error=0                       \
                    tr --delete '%'                 |
        whiptail    --backtitle "$PROGRAM_NAME"     \
                    --title     "$title"            \
                    --gauge     "$title..."         \
                    6 50 0                          || RESTORE_RC=$?
    fi
}


# This function restores the user settings.
function restore_settings() {
    local settings_dir=$HOME/Settings

    if [[ -n ${DISPLAY-} ]]; then
        kz.logmsg 'Restore settings...'
        restore_setting_desktop
    fi
}


# This function restores the desktop background,.
function restore_setting_desktop() {
    local input_file=$settings_dir/desktop.ico

    if type gsettings |& $PROGRAM_LOGS && [[ -f $input_file ]]; then
        kz.logmsg 'Restore the desktop background...'
        gsettings   set                                         \
                    org.gnome.desktop.background picture-uri    \
                    "file://$input_file"
    fi
}


# This function controls the termination of the script.
function term() {
    local -i num_users=0
    local program_name=${PROGRAM_NAME/kz-/kz }
    local text=''
    local title=''
    local user=''
    local users=''
    local usb_mount_point=/media/$USER

    if grep --quiet rhel /etc/os-release; then
        usb_mount_point=/run/media/$USER
    fi

    # Error-log (stderr) also to the main log.
    kz.logmsg '---------------------------------------------------------------'
    printf '%s' "$(<"$ERROR_LOG")" |& $PROGRAM_LOGS
    kz.logmsg '---------------------------------------------------------------'

    if [[ $RESTORE_RC -ne 0 ]]; then
        title="$PROGRAM_DESC $(gettext 'error messages')"
        text="$(gettext 'Restore ended with errors.')

$(gettext 'Possible causes:')
$(gettext 'Were any files added or deleted during the restore, or')
$(gettext 'some files may not be readable or changeable, or')
$(eval_gettext "is there not enough space on \$HOME.")

$(gettext 'Actions to take:')
$(gettext 'Check the error messages after this.')
$(gettext 'Try restoring the back up again.')"
        kz.errmsg "$text"

        if $GUI_MODE; then
            zenity  --text-info             \
                    --filename="$ERROR_LOG" \
                    --width     700         \
                    --height    500         \
                    --title     "$title"    \
                    2> /dev/null            || true
        else
            whiptail    --backtitle "$PROGRAM_NAME" \
                        --title     "$title"        \
                        --textbox   "$ERROR_LOG"    \
                        25 80
        fi
        exit 1
    fi

    num_users=$(find /home/* -prune -print | wc --lines)
    if [[ $num_users -eq 1 ]]; then
        text=$(eval_gettext "The backup has been restored.")
    else
        # shellcheck disable=SC2034
        user=$(
            grep    "$USER"         \
                    /etc/passwd     |
            cut     --delimiter=':' \
                    --fields=5      |
            sed     --expression='s/,//g'
            )
        users=$(
            grep    /bin/bash               \
                    /etc/passwd             |
            grep    root                    \
                    --invert-match          |
            cut     --delimiter=':'         \
                    --fields=5              |
            sed     --expression='s/,//g'
            )
        text="$(eval_gettext "The backup has been restored for \$user, there \
are \$num_users users:")
$users"
    fi

    if [[ $SOURCE == $usb_mount_point* ]]; then
        medium=$(find "$usb_mount_point/"* -prune || true)
        if [[ $(printf '%s\n' "$medium" | wc --lines) -gt 1 ]]; then
            text+="

$(eval_gettext "The backup \$SOURCE has been restored, more than one USB \
medium is connected:")
$medium"
        fi
        text+="

$(gettext '*** Remember to safely(!) remove the USB medium ***')"
    fi

    kz.infomsg "$text"

    exit 0
}


# #############################################################################
# Main
# #############################################################################

function main() {
    kz.init "$@"
    process "$@"
    term
}

main "$@"
