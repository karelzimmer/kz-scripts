# #############################################################################
# Imports
# #############################################################################

import getopt
import gettext
import kz_common as kz
import subprocess
import sys

gettext.bindtextdomain('kz', '/usr/share/locale')
gettext.textdomain('kz')
_ = gettext.gettext


# #############################################################################
# Constants
# #############################################################################

PROGRAM_NAME: str = 'kz-wifi'
PROGRAM_DESC: str = _('Show WiFi details')

USAGE: str = _(
    "Usage: kz wifi [-C|--cli] [-g|--gui] [-h|--help] [-m|--manual]\n"
    "               [-T|--tui] [-u|--usage] [-v|--version]"
    )

HELP_LINES: list[str] = [
    _('Usage: kz wifi [<options>]'),
    '',
    f'{PROGRAM_DESC}.',
    '',
    _('Options:'),
    _('  -C, --cli      run in command-line mode'),
    _('  -g, --gui      run in graphical mode'),
    _('  -h, --help     show this help text'),
    _('  -m, --manual   show manual page'),
    _('  -T, --tui      run in text-based mode (default)'),
    _('  -u, --usage    show a short usage summary'),
    _('  -v, --version  show program version'),
    ]
HELP: str = '\n'.join(HELP_LINES)
del HELP_LINES

OPTIONS_SHORT: str = 'CghmTuv'
OPTIONS_LONG: list[str] = ['cli', 'gui', 'help', 'manual', 'tui', 'usage',
                           'version']


# #############################################################################
# Globals
# #############################################################################

UI_MODE: str = 'tui'


# #############################################################################
# Functions
# #############################################################################

def process(UI_MODE: str = 'tui') -> None:
    """
    This function performs the script actions.
    """
    UI_MODE = check_input(PROGRAM_NAME, PROGRAM_DESC, USAGE, HELP)

    show_secrets(PROGRAM_NAME, PROGRAM_DESC, UI_MODE)


def check_input(PROGRAM_NAME: str, PROGRAM_DESC: str, USAGE: str,
                HELP: str) -> str:
    """
    This function checks the script input.
    """
    args: list[str] = []
    err: BaseException
    opts: list[tuple[str, str]] = []
    program_name: str = PROGRAM_NAME.replace('kz-', 'kz ')
    text: str

    try:
        opts, args = getopt.gnu_getopt(sys.argv[1:], OPTIONS_SHORT,
                                       OPTIONS_LONG)
    except getopt.error as err:
        text = f'{program_name}: {err}\n{USAGE}'
        kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, 'cli', text)
        kz.term(PROGRAM_NAME, 1)

    UI_MODE = process_options(PROGRAM_NAME, PROGRAM_DESC, USAGE, HELP, opts,
                              args)

    return UI_MODE


def process_options(PROGRAM_NAME: str, PROGRAM_DESC: str, USAGE: str,
                    HELP: str, opts: list[tuple[str, str]],
                    args: list[str]) -> str:
    """
    This function handles the script options and arguments.
    """
    arg: str = ''
    opt: str = ''
    program_name: str = PROGRAM_NAME.replace('kz-', 'kz ')
    text: str
    UI_MODE: str = 'tui'

    for opt, arg in opts:
        if opt in ('-C', '--cli'):
            UI_MODE = 'cli'
        elif opt in ('-g', '--gui'):
            if subprocess.run('[[ -n ${DISPLAY-} ]]', executable='bash',
                              stdout=subprocess.DEVNULL,
                              stderr=subprocess.DEVNULL,
                              shell=True,).returncode != 0:
                UI_MODE = 'cli'
                text = (
                    f'{PROGRAM_NAME}: {opt}: '
                    f'{_('no desktop environment available')}'
                    )
                kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, UI_MODE, text)
                kz.term(PROGRAM_NAME, 1)
            UI_MODE = 'gui'
        elif opt in ('-h', '--help'):
            kz.process_option_help(PROGRAM_NAME, PROGRAM_DESC, HELP)
            kz.term(PROGRAM_NAME, 0)
        elif opt in ('-m', '--manual'):
            kz.process_option_manual(PROGRAM_NAME, PROGRAM_DESC)
            kz.term(PROGRAM_NAME, 0)
        elif opt in ('-T', '--tui'):
            UI_MODE = 'tui'
        elif opt in ('-u', '--usage'):
            kz.process_option_usage(PROGRAM_NAME, PROGRAM_DESC, USAGE)
            kz.term(PROGRAM_NAME, 0)
        elif opt in ('-v', '--version'):
            kz.process_option_version(PROGRAM_NAME, PROGRAM_DESC)
            kz.term(PROGRAM_NAME, 0)
        else:
            text = f'{PROGRAM_NAME}: getopt: {_('internal error')}'
            kz.errmsg(PROGRAM_NAME, PROGRAM_DESC, UI_MODE, text)
            kz.term(PROGRAM_NAME, 1)

    if args:
        text = (
            f"{program_name}: {' '.join(args)}: "
            f"{_('arguments are not allowed')}\n{USAGE}"
            )
        kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, UI_MODE, text)
        kz.term(PROGRAM_NAME, 1)

    return UI_MODE


def show_secrets(PROGRAM_NAME: str, PROGRAM_DESC: str,
                 UI_MODE: str = 'tui') -> None:
    """
    This function shows the Wi-Fi secrets.
    """
    command: str = 'pkexec /usr/bin/kz-wifi-pkexec'
    nmcli_output: bytes
    text: str = _('Use this data to connect to the wireless network.')

    if UI_MODE in ('gui', 'tui'):
        try:
            nmcli_output = subprocess.run(command, executable='bash',
                                          stdout=subprocess.PIPE,
                                          stderr=subprocess.DEVNULL,
                                          shell=True, check=True,
                                          ).stdout
        except Exception:
            text = _('No WiFi device found.')
            kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, UI_MODE, text)
        else:
            text = f'{str(nmcli_output.decode("utf-8"))}{text}'
            kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, UI_MODE, text)
    else:
        try:
            # Shows in Terminal QR code for quick connection to Wi-Fi network.
            subprocess.run(command, executable='bash',
                           stderr=subprocess.DEVNULL, shell=True, check=True)
        except Exception:
            text = _('No WiFi device found.')
            kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, UI_MODE, text)
        else:
            kz.infomsg(PROGRAM_NAME, PROGRAM_DESC, UI_MODE, text)


def term() -> None:
    """
    This function controls the termination of the script.
    """
    kz.term(PROGRAM_NAME, 0, UI_MODE)


# #############################################################################
# Main
# #############################################################################

kz.init(PROGRAM_NAME)
process()
term()
