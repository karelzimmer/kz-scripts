#!/usr/bin/env bash
# shellcheck source=kz_common.sh
# #############################################################################
# SPDX-FileComment: Install apps and change system settings.
#
# SPDX-FileCopyrightText: Karel Zimmer <info@karelzimmer.nl>
# SPDX-License-Identifier: CC0-1.0
# #############################################################################


# #############################################################################
# Imports
# #############################################################################

source kz_common.sh as kz


# #############################################################################
# Constants
# #############################################################################

readonly PROGRAM_NAME='kz-install'
PROGRAM_DESC=$(gettext 'Install apps and change system settings')
readonly PROGRAM_DESC
readonly PROGRAM_LOGS="systemd-cat --identifier=$PROGRAM_NAME"

USAGE=$(gettext "\
Usage: kz install [-b|--browse] [-c|--cat] [-C|--cli] [-f|--file <file>]...
                  [-G|--gui] [-h|--help] [-l|--list] [-m|--manual]
                  [-r|--remove] [-s|--select] [-T|--tui] [-u|--usage]
                  [-v|--version] [<app>...]")
readonly USAGE

HELP="$(gettext 'Usage: kz install [<options>] [<arguments>]')

$PROGRAM_DESC.

$(gettext 'Options:')
$(gettext "  Mandatory arguments to long options are mandatory for short \
options too.")

$(gettext '  -b, --browse   browse through all commands and information')
$(gettext '  -c, --cat      show selected commands and information')
$(gettext '  -C, --cli      run in command-line mode')
$(gettext '  -f, --file <file>
                 process specified installation files')
$(gettext '  -G, --gui      run in graphical mode')
$(gettext '  -h, --help     show this help text')
$(gettext '  -l, --list     show available apps')
$(gettext '  -m, --manual   show manual page')
$(gettext '  -r, --remove   delete apps')
$(gettext '  -s, --select   select apps')
$(gettext '  -T, --tui      run in text-based mode (default)')
$(gettext '  -u, --usage    show a short usage summary')
$(gettext '  -v, --version  show program version')

$(gettext 'Arguments:')
$(gettext '  <app>          process specified apps')"
readonly HELP

readonly OPTIONS_SHORT='bcCf:GhlmrsTuv'
readonly OPTIONS_LONG="browse,cat,cli,file:,gui,help,list,manual,remove,\
select,tui,usage,version"


# #############################################################################
# Globals
# #############################################################################

declare -A FAILED_APPS=()
declare ERROR_LOG=''
declare OPTION_REMOVE=false
declare OPTION_SELECT=false
declare REBOOT=false
declare UI_MODE='tui'
declare INSTALL='Install:'
declare REMOVE='Remove:'


# #############################################################################
# Functions
# #############################################################################

# This function performs the script actions.
function process() {
    local -A app_arguments=()
    local -a installation_files=()
    local -i installation_file_num=0
    local argument_app=false
    local command_file=''
    local err_flag=false
    local installation_file_decrypted=''
    local installation_file_default=/usr/bin/$PROGRAM_NAME.sh
    local installation_file=''
    local option_browse=false
    local option_cat=false
    local option_file=false
    local option_list=false
    local text=''

    check_input "$@"

    if ! $option_file; then
        installation_files[++installation_file_num]=$installation_file_default

        # Decrypt GPG-encrypted installation file.
        installation_file_decrypted=\
$(mktemp -t "$PROGRAM_NAME-decrypted-XXXXXXXXXX.sh")
        gpg --no-default-keyring                        \
            --keyring /usr/share/kz/kz-public-key.gpg   \
            --decrypt /usr/bin/kz-install.sh.gpg        \
            > "$installation_file_decrypted"            \
            2> >($PROGRAM_LOGS)

        installation_files[++installation_file_num]=\
$installation_file_decrypted
    fi

    for installation_file in "${installation_files[@]}"; do
        if ! [[ -f $installation_file ]]; then
            text=$(eval_gettext "Installation file '\$installation_file' not \
found.")
            kz.errmsg "$text"
            err_flag=true
        fi
    done
    if $err_flag; then
        exit 1
    fi

    if $option_browse; then
        process_option_browse
        exit 0
    fi

    if $option_list; then
        process_option_list
        exit 0
    fi

    command_file=$(mktemp -t "$PROGRAM_NAME-commands-XXXXXXXXXX.sh")
    # To minimize the risk of errors due to outdated Debian package lists.
    if  grep    --quiet             \
                --regexp='debian'   \
                /etc/os-release     &&
        [[ $INSTALL = 'Install:' ]]; then
        printf '%s\n' "# Install: update | Refresh package lists *** automatic\
ally added ***
# Host:    *
sudo apt-get update
"       > "$command_file"
    fi

    if $OPTION_SELECT; then
        process_option_select
    fi

    if $argument_app; then
        process_argument_app
    else
        process_installation_files_by_hostname
    fi

    if $option_cat; then
        process_option_cat
        exit 0
    fi

    become_check
    install_apps
}


# This function checks the script input.
function check_input() {
    local parsed=''
    local program_name=${PROGRAM_NAME/kz-/kz }

    parsed=$(
        getopt  --options       "$OPTIONS_SHORT"    \
                --longoptions   "$OPTIONS_LONG"     \
                --name          "$program_name"     \
                --              "$@"
        )   ||  {
                    UI_MODE='cli'
                    kz.infomsg "$USAGE"
                    exit 1
                }
    eval set -- "$parsed"
    unset parsed

    process_options "$@"
}


# This function handles the script options and arguments.
function process_options() {
    local program_name=${PROGRAM_NAME/kz-/kz }
    local text=''

    while true; do
        case $1 in
            -b | --browse )
                option_browse=true
                shift
                ;;
            -c | --cat )
                option_cat=true
                shift
                ;;
            -C | --cli )
                UI_MODE='cli'
                shift
                ;;
            -f | --file )
                option_file=true
                installation_files[++installation_file_num]=$2
                shift 2
                ;;
            -G | --gui )
                if [[ -z ${XDG_CURRENT_DESKTOP-} ]]; then
                    text="$program_name: $1: \
$(gettext "no desktop environment available")"
                    kz.infomsg "$text"
                    exit 1
                fi
                UI_MODE='gui'
                shift
                ;;
            -h | --help )
                kz.process_option_help
                exit 0
                ;;
            -l | --list )
                option_list=true
                shift
                ;;
            -m | --manual )
                kz.process_option_manual
                exit 0
                ;;
            -r | --remove )
                OPTION_REMOVE=true
                INSTALL='Remove:'
                REMOVE='Install:'
                shift
                ;;
            -s | --select )
                OPTION_SELECT=true
                shift
                ;;
            -T | --tui )
                UI_MODE='tui'
                shift
                ;;
            -u | --usage )
                kz.process_option_usage
                exit 0
                ;;
            -v | --version )
                kz.process_option_version
                exit 0
                ;;
            -- )
                shift
                break
                ;;
            * )
                text="$PROGRAM_NAME: getopt: $(gettext 'internal error')"
                kz.errmsg "$text"
                exit 1
                ;;
        esac
    done

    if [[ -n $* ]]; then
        argument_app=true
        while [[ -n $* ]]; do
            app_arguments[$1]=$1
            shift
        done
    fi
}


# This function browses through the installation files.
function process_option_browse() {
    local title=''
    local installation_file_combined=''

    installation_file_combined=\
$(mktemp -t "$PROGRAM_NAME-installation-XXXXXXXXXX.sh")
    cat "${installation_files[@]}" > "$installation_file_combined"

    title="$installation_file_combined"

    if [[ $UI_MODE = 'gui' ]]; then
        zenity  --text-info                                 \
                --filename="$installation_file_combined"    \
                --width     700                             \
                --height    500                             \
                --title     "$title"                        \
                2> /dev/null                                || true
    elif [[ $UI_MODE = 'tui' ]]; then
        dialog  --mouse                                     \
                --scrollbar                                 \
                --backtitle "$PROGRAM_NAME"                 \
                --title     "$title"                        \
                --textbox   "$installation_file_combined"   \
                0 0                                         || true
    else
        less --no-init --quit-if-one-screen "$installation_file_combined"
    fi
}


# This function shows the available apps from the installation files.
function process_option_list() {
    local -a app_list=()
    local -a choices=()
    local app_desc=''
    local app_name=''
    local app_list_row=''
    local text=''
    local text_file=''
    local title=''

    text=$(gettext 'The following apps are available:')
    title=$text

    make_app_list
    if [[ -z ${app_list[*]} ]]; then
            text+="
$(gettext 'No apps found.')"
        kz.infomsg "$text"
        exit 0
    fi
    for app_list_row in "${app_list[@]}"; do
        read -r app_name app_desc <<< "$app_list_row"
        choices+=("$app_name" "$app_desc")
    done

    if [[ $UI_MODE = 'gui' ]]; then
        text=$(
            printf '%s|%s\n'            \
                    "${choices[@]}"     |
            column  --table             \
                    --separator '|'
            )
        printf  '%s\n'                  \
                "$text"                 |
        zenity  --text-info             \
                --width     900         \
                --height    500         \
                --title     "$title"    \
                --font="Monospace 10"   \
                2> /dev/null            || true
    elif [[ $UI_MODE = 'tui' ]]; then
        text=$(
            printf '%s|%s\n'                \
                    "${choices[@]}"         |
            column  --table                 \
                    --separator '|'
            )
        text_file=$(mktemp -t "$PROGRAM_NAME-app-list-XXXXXXXXXX.txt")
        printf  '%s\n'                      \
                "$text"                     \
                > "$text_file"
        dialog  --mouse                     \
                --scrollbar                 \
                --backtitle "$PROGRAM_NAME" \
                --title     "$title"        \
                --textbox   "$text_file"    \
                0 0                         || true
    else
        make_cli_app_list
        if [[ $INSTALL = 'Install:' ]]; then
            text+="

$(gettext "Use \"kz install <app>...\" or \"kz install --select\" to install \
the self-selected apps.")
$(gettext "Use \"kz install --cat <app>...\" to view the self-selected \
commands and information.")
$(gettext "Use \"kz install --cat\" to view the automatically selected \
commands and information.")"
       else
            text+="

$(gettext "Use \"kz install --remove <app>...\" or \"kz install --remove \
--select\" to remove the self-selected apps.")
$(gettext "Use \"kz install --cat --remove <app>...\" to view the \
self-selected commands and information.")
$(gettext "Use \"kz install --cat --remove\" to view the automatically \
selected commands and information.")"
        fi
        text+="
$(gettext "Use \"kz install --browse\" to view all commands and information.")"
        kz.infomsg "$text"
    fi
}


# This function makes a list of available apps and descriptions from the
# installation files.
function make_app_list() {
    local app_records=''
    # In calling function declare at least:
    # local -a app_list=()
    # local app_list_row=''

    # +-----------------------------------------------------------------------+
    # | From (app record):
    # | "# Install: <app> | <description>"
    # | To (app list row):
    # | "<app> <description>"
    # +-----------------------------------------------------------------------+
    app_records=$(
        grep    --regexp="# .*${INSTALL}.*" \
                "${installation_files[@]}"  |
        tr      --delete '|'                |
        tr      --squeeze-repeats ' '       |
        cut     --delimiter=' '             \
                --fields=3-                 |
        sort    --unique                    || true
        )
    readarray -t app_list <<< "$app_records"

    # In calling function use app_list like this:
    # for app_list_row in "${app_list[@]}"; do
    #     read -r app_name app_desc <<< "$app_list_row"
    #     ...
    # done
}


# This function makes a list of available apps and descriptions for option cli.
function make_cli_app_list() {
    text+='\n'
    text+=$(
        printf '|%s|%s\n'       \
                "${choices[@]}" |
        column  --table         \
                --separator '|' \
                --output-separator '    '
        )
}


# This function let the user select apps.
function process_option_select() {
    local -a app_list=()
    local -a choices=()
    local app_desc=''
    local app_name=''
    local app_list_row=''
    local text=''
    local title=''

    if [[ $INSTALL = 'Install:' ]]; then
        title=$(gettext 'Install apps')
        text=$(gettext 'Select apps to install:')
    else
        title=$(gettext 'Remove apps')
        text=$(gettext 'Select apps to remove:')
    fi

    make_app_list
    if [[ -z ${app_list[*]} ]]; then
            text+="
$(gettext 'No apps found.')"
        kz.infomsg "$text"
        exit 0
    fi

    if [[ $UI_MODE = 'gui' ]]; then
        for app_list_row in "${app_list[@]}"; do
            read -r app_name app_desc <<< "$app_list_row"
            choices+=('false' "$app_name" "$app_desc")
        done
        # The variable selected_apps does not need to be an array, because the
        # app name does not contain spaces.
        selected_apps=$(
            zenity  --list                                  \
                    --checklist                             \
                    --separator ' '                         \
                    --width     800                         \
                    --height    500                         \
                    --title     "$title"                    \
                    --text      "$text"                     \
                    --ok-label  "$(gettext 'Continue')"     \
                    --column    "$(gettext 'Sel')"          \
                    --column    "$(gettext 'App')"          \
                    --column    "$(gettext 'Description')"  \
                    "${choices[@]}"                         \
                    2> /dev/null                            || true
            )
    elif [[ $UI_MODE = 'tui' ]]; then
        for app_list_row in "${app_list[@]}"; do
            read -r app_name app_desc <<< "$app_list_row"
            choices+=("$app_name" "$app_desc" 'off')
        done
        # The variable selected_apps does not need to be an array, because the
        # app name does not contain spaces.
        selected_apps=$(
            dialog  --ok-label  "$(gettext 'Continue')" \
                    --backtitle "$PROGRAM_NAME"         \
                    --title     "$title"                \
                    --separate-output                   \
                    --checklist "$text"                 \
                    0 0 0                               \
                    "${choices[@]}"                     \
                    2>&1 >/dev/tty                      || true
            )
    else
        for app_list_row in "${app_list[@]}"; do
            read -r app_name app_desc <<< "$app_list_row"
            choices+=("$app_name" "$app_desc")
        done
        make_cli_app_list
        if [[ $INSTALL = 'Install:' ]]; then
            text+="

$(gettext "Use \"kz install <app>...\" or \"kz install --select\" to install \
the self-selected apps.")
$(gettext "Use \"kz install\" to install the automatically selected apps.")"
        else
            text+="

$(gettext "Use \"kz install --remove <app>...\" or \"kz install --remove \
--select\" to remove the self-selected apps.")
$(gettext "Use \"kz install\" to remove the automatically selected apps.")"
        fi
        kz.infomsg "$text"
        exit 0
    fi
    if [[ -z $selected_apps ]]; then
        text=$(gettext 'No apps selected.')
        kz.infomsg "$text"
        exit 0
    fi

    argument_app=true
    for selected_app in $selected_apps; do
        app_arguments[$selected_app]=$selected_app
    done
}


# This function processes argument <app>.
function process_argument_app() {
    local app_argument=''
    local err_flag=false
    local text=''

    for app_argument in "${app_arguments[@]}"; do
        process_installation_files_by_app_argument
    done

    if $err_flag; then
        kz.errmsg "$text"
        exit 1
    fi
}


# This function generates the command file from the installation file and
# filters by <app>.
function process_installation_files_by_app_argument() {
    local app_match=false
    local app_record=''
    local host_record=''
    local install_record=''
    local no_app_match=true
    local write_saved_records=false

    # +-----------------------------------------------------------------------+
    # | # Install: <app> | <description>    [1] "app record"    <== Selection
    # | # Host:    <host>...                [2] "host record"
    # | <cmd>...
    # |
    # | # Remove:  <app> | <description>    [1] "app record"
    # | <cmd>...
    # +-----------------------------------------------------------------------+
    while read -r install_record; do
        case $install_record in
            '# '*${INSTALL}*' '$app_argument' '* )
                # Save app record.
                app_record=$install_record  # [1]
                # Set switches.
                app_match=true
                no_app_match=false
                write_saved_records=true
                ;;
            '# '*'Host:'* )
                # Save host record.
                host_record=$install_record # [2]
                ;;
            '# '*${REMOVE}* | '# EOF' )
                # Stop at mismatched app record or End-Of-File.
                # Reset switches.
                app_match=false
                write_saved_records=false
                ;;
            * )
                if $app_match; then
                    if $write_saved_records; then
                        # Write saved records to the command file.
                        printf '%s\n' "$app_record"     # [1]
                        printf '%s\n' "$host_record"    # [2]
                        write_saved_records=false
                    fi
                    # Add record to command file.
                    printf '%s\n' "$install_record"
                fi
                ;;
        esac
    done < <(cat "${installation_files[@]}") >> "$command_file"

    if $no_app_match; then
        err_flag=true
        text+=$(eval_gettext "App '\$app_argument' not found.")'\n'
    fi
}


# This function generates the command file from the installation file and
# filters by host.
function process_installation_files_by_hostname() {
    local app_match=false
    local app_record=''
    local host_match=false
    local host_record=''
    local install_record=''
    local write_saved_records=false

    # +-----------------------------------------------------------------------+
    # | # Install: <app> | <description>    [1] "app record"
    # | # Host:    <host>...                [2] "host record"   <== Selection
    # | <cmd>...
    # |
    # | # Remove:  <app> | <description>    [1] "app record"
    # | <cmd>...
    # +-----------------------------------------------------------------------+
    while read -r install_record; do
        case $install_record in
            '#'*" ${INSTALL} "* )
                # Save app record.
                app_record=$install_record    # [1]
                # Set switch.
                app_match=true
                # Switch app_match is here not literally a match on app name,
                # like in the function that processes argument <app>, but is
                # required for the remove option because matches on <host> also
                # causes install commands to be included with the remove
                # commands.
                ;;
            '# '*'Host:'*'*'* | '# '*'Host:'*$HOSTNAME* )
                # Save host record.
                host_record=$install_record   # [2]
                # Set switches.
                host_match=true
                write_saved_records=true
                ;;
            '# '*${REMOVE}* | '# EOF' )
                # Stop at mismatched app record or End-Of-File.
                # Reset switches.
                app_match=false
                host_match=false
                write_saved_records=false
                ;;
            * )
                if $app_match && $host_match; then
                    if $write_saved_records; then
                        # Write saved records to the command file.
                        printf '%s\n' "$app_record"     # [1]
                        printf '%s\n' "$host_record"    # [2]
                        write_saved_records=false
                    fi
                    # Add record to command file.
                    printf '%s\n' "$install_record"
                fi
                ;;
        esac
    done < <(cat "${installation_files[@]}") >> "$command_file"
}


# This function displays the contents of the command file.
function process_option_cat() {
    local title=''

    title="$command_file"

    if [[ $UI_MODE = 'gui' ]]; then
        zenity  --text-info                 \
                --filename="$command_file"  \
                --width     700             \
                --height    500             \
                --title     "$title"        \
                2> /dev/null                || true
    elif [[ $UI_MODE = 'tui' ]]; then
        dialog  --mouse                     \
                --scrollbar                 \
                --backtitle "$PROGRAM_NAME" \
                --title     "$title"        \
                --textbox   "$command_file" \
                0 0                         || true
    else
        less --no-init --quit-if-one-screen "$command_file"
    fi
}


# This function returns 0 if the user is root or can become root, otherwise
# exits 0 with descriptive message.
function become_check() {
    local text=''

    if [[ $UID -eq 0 ]]; then
        return 0
    elif groups "$USER" | grep --quiet --regexp='sudo' --regexp='wheel'; then
        return 0
    else
        text=$(gettext 'Already performed by the administrator.')
        if [[ ${UI_MODE-} = 'cli' ]]; then
            text=$GREEN$text$NORMAL
        fi
        kz.infomsg "$text"
        exit 0
    fi
}


# This function starts installing the apps.
function install_apps() {
    local -i app_tot_num=0
    local text=''
    local title=''

    app_tot_num=$(
        grep    --count                     \
                --regexp="# .*${INSTALL}.*" \
                "$command_file"             || true
                )
    if [[ $app_tot_num -eq 0 ]]; then
        text=$(gettext 'No commands to execute.' )
        kz.infomsg "$text"
        exit 0
    fi

    ERROR_LOG=$(mktemp -t "$PROGRAM_NAME-error-XXXXXXXXXX.log")
    chmod --verbose 775 "$ERROR_LOG" |& $PROGRAM_LOGS
    text="\
== $ERROR_LOG (stderr) ======================================================="
    printf '%s\n' "$text" > "$ERROR_LOG"

    title=$(gettext 'Install apps')
    text=$(gettext 'Prepare installation')

    if [[ $UI_MODE = 'gui' ]]; then
        # With '|& zenity --progress' global variables from called functions
        # are not passed, hence the process substitution with '> >(zenity...)'.
        process_command_file > >(
            zenity  --progress              \
                    --pulsate               \
                    --auto-close            \
                    --no-cancel             \
                    --width     700         \
                    --height    50          \
                    --title     "$title"    \
                    --text      "$text"     \
                    2> /dev/null
            )
    else
        process_command_file
    fi
}


# This function reads commands from the command file for further processing.
function process_command_file() {
    local -i app_seq_num=0
    local app_name_line=''
    local app_name=''
    local command_record=''
    local text=''

    text="$(gettext "Authentication is required to install apps and change \
system settings")
"
    # Skip user prompts during installations or upgrades.
    # This ensures an uninterrupted, automated installation process.
    export DEBIAN_FRONTEND=noninteractive

    if [[ $UI_MODE = 'cli' ]]; then
        sudo --validate
        text="$(gettext 'Num/Tot  App | Description')
         $(gettext 'Command')..."
        printf '%s\n' "$text"
    fi

    while read -r command_record; do
        case $command_record in
            '' )
                # Skip empty line.
                continue
                ;;
            '# '*${INSTALL}' '* )
                # App record.
                app_name=$(
                    printf '%s\n' "$command_record" |
                    tr --squeeze-repeats ' '        |
                    cut --delimiter=' ' --fields=3-
                    )
                (( ++app_seq_num ))
                printf  -v app_name_line    \
                        "%3d/%-3d  %s"      \
                        "$app_seq_num"      \
                        "$app_tot_num"      \
                        "$app_name"
                if [[ $UI_MODE = 'cli' ]]; then
                    printf '%s\n' "$app_name_line"
                fi
                # To corrolate possible error messages with app name.
                printf '%s\n' "== App $app_name" >> "$ERROR_LOG"
                ;;
            '#'* )
                # Skip comment record.
                continue
                ;;
            * )
                # Process command record.
                execute_command "$command_record"
                ;;
        esac
    done < "$command_file"
}


# This function reports and executes a command from the command file.
function execute_command() {
    local cmd=$1
    local -i cmd_dis_len=0
    local -i cmd_dis_max=0
    local cmd_dis=''
    local -i pkexec_rc=0

    kz.logmsg "$app_name_line\n\n         $cmd"

    if [[ $UI_MODE = 'gui' ]]; then
        printf '%s\n' "#$app_name_line\n\n$cmd"
        check_debian_package_manager
        pkexec  /usr/bin/kz-install-pkexec  \
                "${XDG_CURRENT_DESKTOP-}"   \
                "$cmd"                      \
                1> >($PROGRAM_LOGS)         \
                2>> "$ERROR_LOG"            || pkexec_rc=$?
        if [[ $pkexec_rc -eq 126 ]]; then
            text=$(gettext 'Authentication is required to continue.')
            kz.errmsg "$text"
            exit 1
        elif [[ $pkexec_rc -ne 0 ]]; then
            FAILED_APPS[$app_name]=$app_name
        fi
        if [[ $cmd = 'REBOOT=true' ]]; then
            REBOOT=true
        fi
    elif [[ $UI_MODE = 'tui' ]]; then
        while true; do
            if sudo --non-interactive --validate 2> /dev/null; then
                break
            else
                if ! sudo   --stdin <<< "$(
                            dialog  --insecure                      \
                                    --backtitle     "$PROGRAM_NAME" \
                                    --title         "$PROGRAM_DESC" \
                                    --passwordbox   "$text"         \
                                    0 0                             \
                                    2>&1 >/dev/tty                  || true
                            )" true 2> /dev/null; then
                    text=$(gettext 'Authentication is required to continue.')
                    kz.errmsg "$text"
                    exit 1
                fi
            fi
        done
        # This tput locks the cursor position top-left to prevent flickering.
        tput cup 0 0
        dialog  --backtitle "$PROGRAM_NAME"                     \
                --title     "$title"                            \
                --infobox   "$app_name_line\n\n         $cmd"   \
                10 90                                           || true
        check_debian_package_manager
        eval    "$cmd"              \
                1> >($PROGRAM_LOGS) \
                2>> "$ERROR_LOG"    || FAILED_APPS[$app_name]=$app_name
    else
        # Ellipsize terminal output.
        # Width 9 characters less, 9 for leading spaces.
        cmd_dis_max=$(( $(tput cols) - 9 ))
        if [[ ${#cmd} -gt $cmd_dis_max ]]; then
            # Width 12 characters less, 9 for leading spaces and 3 for trailing
            # ellipsis.
            cmd_dis_len=$(( $(tput cols) - 12 ))
            cmd_dis=${cmd:0:cmd_dis_len}...
        else
            cmd_dis=$cmd
        fi
        sudo --validate
        printf '%s\n' "         $cmd_dis"
        check_debian_package_manager
        eval    "$cmd"              \
                1> >($PROGRAM_LOGS) \
                2>> "$ERROR_LOG"    || FAILED_APPS[$app_name]=$app_name
    fi
}


# This function checks if a Debian package manager is already running and waits
# for the next check if so.
function check_debian_package_manager() {
    local text='Wait for another package manager to finish...'

    if grep --quiet --regexp='rhel\|fedora' /etc/os-release; then
        return 0
    fi

    while pkexec /usr/bin/kz_common-pkexec; do
        kz.logmsg "$text"
        sleep 2
    done
}


# This function controls the termination of the script.
function term() {
    local program_name=${PROGRAM_NAME/kz-/kz }
    local prompt=''
    local reboot='systemctl --check-inhibitors=no reboot'
    local text=''
    local title=''

    # Error log also to the standard log.
    text="\
== $ERROR_LOG (stderr) ======================================================="
    printf '%s\n' "$text" >> "$ERROR_LOG"
    printf '%s' "$(<"$ERROR_LOG")" |& $PROGRAM_LOGS

    if [[ -n ${FAILED_APPS[*]} ]]; then
        title="$PROGRAM_DESC $(gettext 'error messages')"
        text="$(gettext "The installation of the following apps contains \
errors:")
${FAILED_APPS[*]}

$(gettext 'Actions to take:')
$(gettext 'Check the error messages after this.')
"
        if [[ $INSTALL = 'Install:' ]]; then
            text+=$(gettext 'Try to install the apps again.')
        else
            text+=$(gettext 'Try to remove the apps again.')
        fi
        kz.errmsg "$text"

        if [[ $UI_MODE = 'gui' ]]; then
            zenity  --text-info                 \
                    --filename="$ERROR_LOG"     \
                    --width     700             \
                    --height    500             \
                    --title     "$title"        \
                    2> /dev/null                || true
        elif [[ $UI_MODE = 'tui' ]]; then
            dialog  --mouse                     \
                    --scrollbar                 \
                    --backtitle "$PROGRAM_NAME" \
                    --title     "$title"        \
                    --textbox   "$ERROR_LOG"    \
                    0 0                         || true
        else
            prompt=$(gettext 'Press the Enter key to continue [Enter]: ')
            read -rp "$prompt" < /dev/tty
            kz.infomsg "$title $ERROR_LOG:"
            less --no-init --quit-if-one-screen "$ERROR_LOG"
        fi
        exit 1
    fi

    text=$(gettext "Apps install completed.")
    if $OPTION_REMOVE; then
       text=$(gettext "Apps remove completed.")
    fi

    if $REBOOT; then
        text+="

$(gettext "The computer will now reboot to finish installing the apps and \
changing system settings.")"
    fi
    kz.infomsg "$text"

    if $REBOOT && [[ $UI_MODE = 'cli' ]]; then
        prompt=$(gettext 'Press the Enter key to continue [Enter]: ')
        read -rp "$prompt" < /dev/tty
    fi

    if $REBOOT; then
        if [[ $UI_MODE = 'gui' ]]; then
            pkexec /usr/bin/kz-install-pkexec "$reboot"
        else
            eval "$reboot"
        fi
    fi

    exit 0
}


# #############################################################################
# Main
# #############################################################################

function main() {
    kz.init "$@"
    process "$@"
    term
}

main "$@"
