# #############################################################################

# #############################################################################
# Imports
# #############################################################################

source kz_common.sh as kz


# #############################################################################
# Constants
# #############################################################################

readonly PROGRAM_NAME='kz-menu'
PROGRAM_DESC=$(gettext 'Execute the kz commands through a menu')
readonly PROGRAM_DESC
readonly PROGRAM_LOGS="systemd-cat --identifier=$PROGRAM_NAME"

USAGE=$(gettext "\
Usage: kz menu [-C|--cli] [-G|--gui] [-h|--help] [-m|--manual] [-T|--tui]
               [-u|--usage] [-v|--version]")
readonly USAGE

HELP="$(gettext 'Usage: kz menu [<options>]')

$PROGRAM_DESC.

$(gettext 'Options:')
$(gettext '  -C, --cli      run in command-line mode')
$(gettext '  -G, --gui      run in graphical mode')
$(gettext '  -h, --help     show this help text')
$(gettext '  -m, --manual   show manual page')
$(gettext '  -T, --tui      run in text-based mode (default)')
$(gettext '  -u, --usage    show a short usage summary')
$(gettext '  -v, --version  show program version')"
readonly HELP

readonly OPTIONS_SHORT='CGhmTuv'
readonly OPTIONS_LONG='cli,gui,help,manual,tui,usage,version'

# Define the menu1 options.
MENU1_TITLE=$(gettext 'Installation menu')
readonly MENU1_TITLE
readonly MENU1_HEAD="------------------ $MENU1_TITLE ------------------"
readonly -a  MENU1_ACTIONS=(
    [1]="$(gettext 'Prepare installation')"
    [2]="$(gettext 'Perform installation')"
    [3]="$(gettext 'Finish installation')"
    [4]="$(gettext 'Set up user')"
    [5]="$(gettext 'Command menu')"
    [6]="$(gettext 'Exit')"
    )
readonly -a  MENU1_DESCS=(
    [1]="$(gettext 'Checklist chapter 1')"
    [2]="$(gettext 'Checklist chapter 2')"
    [3]="$(gettext 'Checklist chapter 3')"
    [4]="$(gettext 'Checklist chapter 4')"
    [5]="$(gettext 'Show command menu')"
    [6]="$(gettext 'Exit menu')"
    )
readonly MENU1_LINES=${#MENU1_ACTIONS[@]}

# Define the menu2 options.
MENU2_TITLE=$(gettext 'Command menu')
readonly MENU2_TITLE
readonly MENU2_HEAD="-------------------- $MENU2_TITLE -------------------"
readonly -a  MENU2_ACTIONS=(
    [1]="$(gettext 'Make backup')"
    [2]="$(gettext 'Show WiFi details')"
    [3]="$(gettext 'Install apps')"
    [4]="$(gettext 'Restore backup')"
    [5]="$(gettext 'Set up apps')"
    [6]="$(gettext 'Go to installation menu')"
            )
readonly -a  MENU2_DESCS=(
    [1]='kz-backup'
    [2]='kz-wifi'
    [3]='kz-install'
    [4]='kz-restore'
    [5]='kz-setup'
    [6]="$(gettext 'Back')"
    )
readonly MENU2_LINES=${#MENU2_DESCS[@]}


# #############################################################################
# Globals
# #############################################################################

declare UI_MODE='tui'


# #############################################################################
# Functions
# #############################################################################

# This function performs the script actions.
function process() {
    local -i rc=0

    check_input "$@"
    if [[ $UI_MODE = 'gui' ]]; then
        process_menu1_gui
    elif [[ $UI_MODE = 'tui' ]]; then
        process_menu1_tui
    else
        process_menu1_cli
    fi
}


# This function checks the script input.
function check_input() {
    local parsed=''
    local program_name=${PROGRAM_NAME/kz-/kz }

    parsed=$(
        getopt  --options       "$OPTIONS_SHORT"    \
                --longoptions   "$OPTIONS_LONG"     \
                --name          "$program_name"     \
                --              "$@"
        )   ||  {
                    UI_MODE='cli'
                    kz.infomsg "$USAGE"
                    exit 1
                }
    eval set -- "$parsed"
    unset parsed

    process_options "$@"
}


# This function handles the script options and arguments.
function process_options() {
    local program_name=${PROGRAM_NAME/kz-/kz }
    local text=''

    while true; do
        case $1 in
            -C | --cli )
                UI_MODE='cli'
                shift
                ;;
            -G | --gui )
                if [[ -z ${DISPLAY-} ]]; then
                    text="$program_name: $1: \
$(gettext "no desktop environment available")"
                    kz.infomsg "$text"
                    exit 1
                fi
                UI_MODE='gui'
                shift
                ;;
            -h | --help )
                kz.process_option_help
                exit 0
                ;;
            -m | --manual )
                kz.process_option_manual
                exit 0
                ;;
            -T | --tui )
                UI_MODE='tui'
                shift
                ;;
            -u | --usage )
                kz.process_option_usage
                exit 0
                ;;
            -v | --version )
                kz.process_option_version
                exit 0
                ;;
            -- )
                shift
                break
                ;;
            * )
                text="$PROGRAM_NAME: getopt: $(gettext 'internal error')"
                kz.errmsg "$text"
                exit 1
                ;;
        esac
    done

    if [[ -n $* ]]; then
        text="$program_name: $*: $(gettext 'arguments are not allowed')
$USAGE"
        kz.infomsg "$text"
        exit 1
    fi
}


# This function shows and processes menu 1 in GUI mode.
function process_menu1_gui() {
    local title=$MENU1_TITLE

    while true; do
        REPLY=$(
            zenity  --list                                              \
                    --radiolist                                         \
                    --width         520                                 \
                    --height        420                                 \
                    --title         "$title"                            \
                    --text          "$(gettext 'Select a choice:')"     \
                    --ok-label      "$(gettext 'Continue')"             \
                    --cancel-label  "$(gettext 'Exit')"                 \
                    --column        "$(gettext 'CHOICE')"               \
                    --column        "$(gettext 'NUM')"                  \
                    --column        "$(gettext 'ACTION')"               \
                    --column        "$(gettext 'DESCRIPTION')"          \
                    true  1 "${MENU1_ACTIONS[1]}" "${MENU1_DESCS[1]}"   \
                    false 2 "${MENU1_ACTIONS[2]}" "${MENU1_DESCS[2]}"   \
                    false 3 "${MENU1_ACTIONS[3]}" "${MENU1_DESCS[3]}"   \
                    false 4 "${MENU1_ACTIONS[4]}" "${MENU1_DESCS[4]}"   \
                    false 5 "${MENU1_ACTIONS[5]}" "${MENU1_DESCS[5]}"   \
                    2> /dev/null                                        || true
            )   || exit 0
        process_menu1_choice
    done
}


# This function shows and processes menu 1 in TUI mode.
function process_menu1_tui() {
    local -a items=(
        [1]="$(printf '%-24s' "${MENU1_ACTIONS[1]}") ${MENU1_DESCS[1]}"
        [2]="$(printf '%-24s' "${MENU1_ACTIONS[2]}") ${MENU1_DESCS[2]}"
        [3]="$(printf '%-24s' "${MENU1_ACTIONS[3]}") ${MENU1_DESCS[3]}"
        [4]="$(printf '%-24s' "${MENU1_ACTIONS[4]}") ${MENU1_DESCS[4]}"
        [5]="$(printf '%-24s' "${MENU1_ACTIONS[5]}") ${MENU1_DESCS[5]}"
        )
    local text=''
    local title=''

    title=$(gettext 'Installation menu')
    text=$(gettext 'Select a choice:')

    while true; do
        REPLY=$(
            dialog  --ok-label      "$(gettext 'Continue')" \
                    --cancel-label  "$(gettext 'Exit')"     \
                    --backtitle     "$PROGRAM_NAME"         \
                    --title         "$title"                \
                    --menu          "$text"                 \
                    0 0 0                                   \
                    1 "${items[1]}"                         \
                    2 "${items[2]}"                         \
                    3 "${items[3]}"                         \
                    4 "${items[4]}"                         \
                    5 "${items[5]}"                         \
                    2>&1 >/dev/tty
            )   || exit 0
        process_menu1_choice
    done
}


# This function shows and processes menu 1 in CLI mode.
function process_menu1_cli() {
    local menu1_action=''
    local prompt=''

    while true; do
        printf  '\n%s\n\n%3s  %-24s  %s\n'  \
                "$MENU1_HEAD"               \
                "$(gettext 'NUM')"          \
                "$(gettext 'ACTION')"       \
                "$(gettext 'DESCRIPTION')"
        for menu1_action in "${!MENU1_ACTIONS[@]}"; do
            printf  '%3s  %-24s  %s\n'                  \
                    "$menu1_action"                     \
                    "${MENU1_ACTIONS[$menu1_action]}"   \
                    "${MENU1_DESCS[$menu1_action]}"
        done

        printf '\n'
        prompt=$(eval_gettext "Run number [1-\$MENU1_LINES]: ")
        kz.logmsg "$prompt"
        read -rp "$prompt" < /dev/tty

        case $REPLY in
            *[^[:digit:]]* )
                continue
                ;;
            * )
                if [[ $REPLY -ge 1 && $REPLY -le $MENU1_LINES ]]; then
                    process_menu1_choice
                else
                    continue
                fi
                ;;
        esac
    done
}


# This function processes menu 1 choice.
function process_menu1_choice() {
    local text=''

    case $REPLY in
        1 )
            process_menu1_choice1
            ;;
        2 )
            process_menu1_choice2
            ;;
        3 )
            process_menu1_choice3
            ;;
        4 )
            process_menu1_choice4
            ;;
        5 )
            process_menu2
            ;;
        6 )
            exit 0
            ;;
        * )
            exit 0
            ;;
    esac
}


# This function processes menu 1 choice 1.
function process_menu1_choice1() {
    local -a rows=(
        [1]="${MENU2_ACTIONS[1]}#${MENU2_DESCS[1]}"
        )
    local title="${MENU1_ACTIONS[1]} (${MENU1_DESCS[1]})"

    process_commands
}


# This function processes menu 1 choice 2.
function process_menu1_choice2() {
    local prompt=''
    local text=''
    local title="${MENU1_ACTIONS[2]} (${MENU1_DESCS[2]})"

    text="
$(gettext "Follow the steps as described in Checklist installation, Chapter 2.
Checklist installation can be found on https://karelzimmer.nl/en.

Roughly boils down to:

1. Download a CD image file (.iso).
2. Create a bootable USB stick (see Linux info).
3. Boot the computer from this USB stick.
4. Install Linux.")
"
    kz.infomsg "$text"
    if [[ $UI_MODE = 'cli' ]]; then
        prompt=$(gettext 'Press the Enter key to continue [Enter]: ')
        read -rp "$prompt" < /dev/tty
    fi

}


# This function processes menu 1 choice 3.
function process_menu1_choice3() {
    local -a rows=(
        [1]="${MENU2_ACTIONS[3]}#${MENU2_DESCS[3]}"
        )
    local title="${MENU1_ACTIONS[3]} (${MENU1_DESCS[3]})"

    process_commands
}


# This function processes menu 1 choice 4.
function process_menu1_choice4() {
    local -a rows=(
        [1]="${MENU2_ACTIONS[4]}#${MENU2_DESCS[4]}"
        [2]="${MENU2_ACTIONS[5]}#${MENU2_DESCS[5]}"
        )
    local title="${MENU1_ACTIONS[4]} (${MENU1_DESCS[4]})"

    process_commands
}


# This function processes menu 2.
function process_menu2() {
    if [[ $UI_MODE = 'gui' ]]; then
        process_menu2_gui
    elif [[ $UI_MODE = 'tui' ]]; then
        process_menu2_tui
    else
        process_menu2_cli
    fi
}


# This function shows and processes menu 2 in GUI mode.
function process_menu2_gui() {
    local title=$MENU2_TITLE

    while true; do
        REPLY=$(
            zenity  --list                                              \
                    --radiolist                                         \
                    --width         520                                 \
                    --height        420                                 \
                    --title         "$title"                            \
                    --text          "$(gettext 'Select a choice:')"     \
                    --ok-label      "$(gettext 'Continue')"             \
                    --cancel-label  "$(gettext 'Back')"                 \
                    --column        "$(gettext 'CHOICE')"               \
                    --column        "$(gettext 'NUM')"                  \
                    --column        "$(gettext 'ACTION')"               \
                    --column        "$(gettext 'DESCRIPTION')"          \
                    true  1 "${MENU2_ACTIONS[1]}" "${MENU2_DESCS[1]}"   \
                    false 2 "${MENU2_ACTIONS[2]}" "${MENU2_DESCS[2]}"   \
                    false 3 "${MENU2_ACTIONS[3]}" "${MENU2_DESCS[3]}"   \
                    false 4 "${MENU2_ACTIONS[4]}" "${MENU2_DESCS[4]}"   \
                    false 5 "${MENU2_ACTIONS[5]}" "${MENU2_DESCS[5]}"   \
                    2> /dev/null                                        || true
            )   || break
        process_menu2_choice
    done
}


# This function shows and processes menu 2 in TUI mode.
function process_menu2_tui() {
    local -a items=(
        [1]="$(printf '%-24s' "${MENU2_ACTIONS[1]}") ${MENU2_DESCS[1]}"
        [2]="$(printf '%-24s' "${MENU2_ACTIONS[2]}") ${MENU2_DESCS[2]}"
        [3]="$(printf '%-24s' "${MENU2_ACTIONS[3]}") ${MENU2_DESCS[3]}"
        [4]="$(printf '%-24s' "${MENU2_ACTIONS[4]}") ${MENU2_DESCS[4]}"
        [5]="$(printf '%-24s' "${MENU2_ACTIONS[5]}") ${MENU2_DESCS[5]}"
        )
    local text=''
    local title=''

    title=$(gettext 'Command menu')
    text=$(gettext 'Select a choice:')

    while true; do
        REPLY=$(
            dialog  --ok-label      "$(gettext 'Continue')" \
                    --cancel-label  "$(gettext 'Back')"     \
                    --backtitle     "$PROGRAM_NAME"         \
                    --title         "$title"                \
                    --menu          "$text"                 \
                    0 0 0                                   \
                    1 "${items[1]}"                         \
                    2 "${items[2]}"                         \
                    3 "${items[3]}"                         \
                    4 "${items[4]}"                         \
                    5 "${items[5]}"                         \
                    2>&1 >/dev/tty
            )   || break
        process_menu2_choice
    done
}


# This function shows and processes menu 2 in CLI mode.
function process_menu2_cli() {
    local menu2_action=''
    local prompt=''

    while true; do
        printf  '\n%s\n\n%3s  %-25s  %s\n'  \
                "$MENU2_HEAD"               \
                "$(gettext 'NUM')"          \
                "$(gettext 'ACTION')"       \
                "$(gettext 'DESCRIPTION')"
        for menu2_action in "${!MENU2_ACTIONS[@]}"; do
            printf  '%3s  %-25s  %s\n'                  \
                    "$menu2_action"                     \
                    "${MENU2_ACTIONS[$menu2_action]}"   \
                    "${MENU2_DESCS[$menu2_action]}"
        done

        printf '\n'
        prompt=$(eval_gettext "Run number [1-\$MENU2_LINES]: ")
        kz.logmsg "$prompt"
        read -rp "$prompt" < /dev/tty

        case $REPLY in
            *[^[:digit:]]* )
                continue
                ;;
            * )
                if [[ $REPLY -ge 1 && $REPLY -le $MENU2_LINES ]]; then
                    process_menu2_choice
                else
                    continue
                fi
                ;;
        esac
    done
}


# This function processes menu 2 choice.
function process_menu2_choice() {
    local text=''
    local -a rows=()
    local title=''

    if [[ $REPLY -ge 1 && $REPLY -le $((MENU2_LINES -1)) ]]; then
        rows[1]="${MENU2_ACTIONS[$REPLY]}#${MENU2_DESCS[$REPLY]}"
        title="${MENU2_ACTIONS[$REPLY]} (${MENU2_DESCS[$REPLY]})"
        process_commands
    else
        if [[ $UI_MODE = 'gui' ]]; then
            process_menu1_gui
        elif [[ $UI_MODE = 'tui' ]]; then
            process_menu1_tui
        else
            process_menu1_cli
        fi
    fi
}


# This function processes the command corresponding to the choice made.
function process_commands() {
    local -i row=0
    local command=''
    local description=''
    local execute_command=false

    show_commands_before_execution

    if $execute_command; then
        for row in "${!rows[@]}"; do
            description=$(
                printf '%s' "${rows[$row]}" | cut --delimiter='#' --fields=1
                )
            command=$(
                printf '%s' "${rows[$row]}" | cut --delimiter='#' --fields=2
                )
            title="$description ($command)"
            execute_command
        done
    fi
}


# This function shows the commands before they are executed.
function show_commands_before_execution() {
    local -i row=0
    local command=''
    local description=''
    local prompt=''
    local text=''

    text="$(gettext 'The following will be executed:')
"
    for row in "${!rows[@]}"; do
        description=$(
            printf '%s' "${rows[$row]}" | cut --delimiter='#' --fields=1
            )
        command=$(
            printf '%s' "${rows[$row]}" | cut --delimiter='#' --fields=2
            )
        text+="
$description ($command)"
    done

    if [[ $UI_MODE = 'gui' ]]; then
        text+="

$(gettext 'Proceed?')"
        if zenity   --question                          \
                    --no-markup                         \
                    --width         520                 \
                    --height        100                 \
                    --title         "$title"            \
                    --text          "$text"             \
                    --ok-label      "$(gettext 'Yes')"  \
                    --cancel-label  "$(gettext 'No')"   \
                    2> /dev/null; then
            execute_command=true
        else
            execute_command=false
        fi
    elif [[ $UI_MODE = 'tui' ]]; then
        text+="

$(gettext 'Proceed?')"
        if dialog   --backtitle "$PROGRAM_NAME"         \
                    --title     "$title"                \
                    --yesno     "$text"                 \
                    0 0; then
            execute_command=true
        else
            execute_command=false
        fi
    else
        printf '\n%s\n\n' "$text"
        prompt="$(gettext 'Proceed?')"
        while true; do
            read -rp "$(eval_gettext "\$prompt [Y/n]: ")" < /dev/tty
            case $REPLY in
                [YyJj]* | '' )
                    execute_command=true
                    break
                    ;;
                [Nn]* )
                    execute_command=false
                    break
                    ;;
                * )
                    continue
                    ;;
            esac
        done
    fi
}


# This function executes the commands.
function execute_command() {
    $command --"$UI_MODE" || rc=$?
    kz.logmsg "$command: rc=$rc"
}


# This function controls the termination of the script.
function term() {
    exit 0
}


# #############################################################################
# Main
# #############################################################################

function main() {
    kz.init "$@"
    process "$@"
    term
}

main "$@"
