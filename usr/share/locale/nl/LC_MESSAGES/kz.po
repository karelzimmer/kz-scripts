#, sh-format
msgid "Settings file '$settings_file' not found."
msgstr "Instellingenbestand '$settings_file' niet gevonden."

#: kz-setup:315 kz-setup:422
msgid "Use \"kz setup <app>...\" or \"kz setup --select\" to set up the apps."
msgstr ""
"Gebruik \"kz setup <app>...\" of \"kz setup --select\" om de apps in te "
"stellen."

#: kz-setup:317
msgid ""
"Use \"kz setup --cat <app>...\" to view the contents of the apps command "
"file."
msgstr ""
"Gebruik \"kz setup --cat <app>...\" om de inhoud van het opdrachtbestand "
"voor apps te bekijken."

#: kz-setup:319
msgid "Use  \"kz setup --cat\" to view the contents of the whole command file."
msgstr ""
"Gebruik \"kz setup --cat\" om de inhoud van het hele opdrachtbestand te "
"bekijken."

#: kz-setup:324 kz-setup:427
msgid ""
"Use \"kz setup --reset <app>...\" or \"kz setup --select --reset\" to reset "
"the apps."
msgstr ""
"Gebruik \"kz setup --reset <app>...\" of \"kz setup --select --reset\" om de "
"apps te resetten."

#: kz-setup:326
msgid ""
"Use \"kz setup --cat --reset <app>...\" to view the contents of the apps "
"command file."
msgstr ""
"Gebruik \"kz setup --cat --reset <app>...\" om de inhoud van het "
"opdrachtbestand voor apps te bekijken."

#: kz-setup:328
msgid ""
"Use \"kz setup --cat --reset\" to view the contents of the whole command "
"file."
msgstr ""
"Gebruik \"kz setup --cat --reset\" om de inhoud van het hele opdrachtbestand "
"te bekijken."

#: kz-setup:332
msgid ""
"Use \"kz setup --browse\" to view the contents of the default settings files."
msgstr ""
"Gebruik \"kz setup --browse\" om de inhoud van de standaard "
"instellingenbestanden te bekijken."

#: kz-setup:366
msgid "Select apps to set up:"
msgstr "Selecteer apps om in te stellen:"

#: kz-setup:368
msgid "Reset apps"
msgstr "Apps resetten"

#: kz-setup:369
msgid "Select apps to reset:"
msgstr "Selecteer apps om te resetten:"

#: kz-setup:577
msgid "Preparing set up"
msgstr "Instellen voorbereiden"

#: kz-setup:704
msgid "The set up of the following apps contains errors:"
msgstr "Het instellen van de volgende apps bevat fouten:"

#: kz-setup:711
msgid "Try to set up the apps again."
msgstr "Probeer de apps opnieuw in te stellen."

#: kz-setup:713
msgid "Try to reset the apps again."
msgstr "Probeer de apps opnieuw te resetten."

#: kz-setup:739
msgid "Apps set up completed."
msgstr "Apps instellen is voltooid."

#: kz-setup:741
msgid "Apps reset completed."
msgstr "Apps resetten is voltooid."

#: kz-setup:749
msgid ""
"You will now be logged out of the computer to finish setting up the apps and "
"changing user settings."
msgstr ""
"U wordt nu afgemeld bij de computer om het instellen van de apps en het "
"wijzigen van de gebruikersinstellingen te voltooien."

#: kz-setup:754
msgid ""
"Type 'logout' to log out of the computer to finish setting up the apps and "
"changing user settings."
msgstr ""
"Typ 'logout' om uit te loggen van de computer om het instellen van de apps "
"en het wijzigen van de gebruikersinstellingen te voltooien."

#: kz-setup:776
msgid "Log out of the computer yourself."
msgstr "Meld u zelf af van de computer."

